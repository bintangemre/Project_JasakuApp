@startuml Jasaku — Mitra (Provider) Use Case
!theme plain
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #333333
  FontSize 12
}
skinparam actor {
  BorderColor #2E7D32
  FontSize 14
  FontStyle bold
}
skinparam rectangle {
  BorderColor #2E7D32
  BackgroundColor #E8F5E9
  RoundCorner 10
}
skinparam note {
  BorderColor #2E7D32
  BackgroundColor #E8F5E9
}
skinparam arrow {
  Color #2E7D32
}

left to right direction

actor "Provider\n(Mitra)" as Provider #90EE90

rectangle "Provider (Mitra)" as ProviderRect {
  usecase "Register\n(Multi-step)" as P1
  note right of P1
    Steps:
    1. Select categories
    2. Personal info
    3. Upload documents
       (KTP, selfie, portfolio,
        ijazah, certificates)
    4. KTP OCR scan
    5. Liveness detection
    6. Accept terms
    → Pending admin verification
  end note

  usecase "Login\n(Verification Check)" as P2
  note right of P2
    Blocked if pending/rejected.
    Rejected providers can login
    but see rejection screen
  end note

  usecase "Resubmit\nVerification" as P3
  note right of P3
    Fix documents and resubmit
    after rejection
  end note

  usecase "Complete\nOnboarding" as P4
  note right of P4
    After verified:
    • Upload profile photo
    • Set services & prices
    • Add payout method
  end note

  usecase "Toggle\nAvailability" as P5
  note right of P5
    Separate toggles for:
    • Service orders
    • Custom tasks
  end note

  usecase "View Incoming\nRequests" as P6
  note right of P6
    Pending orders with
    5-minute countdown timer.
    Auto-refresh every 30s
  end note

  usecase "Accept / Reject\nOrder" as P7
  note right of P7
    Accept → status: accepted
    Reject → status: rejected
  end note

  usecase "Update Order\nStatus" as P8
  note right of P8
    Progression:
    accepted → on_the_way
    → arrived → in_progress
    → completed
  end note

  usecase "Request\nExtension" as P9
  note right of P9
    If in_progress, request
    1-3 additional days
    → admin approves/denies
  end note

  usecase "View Schedule\n& Earnings" as P10
  note right of P10
    • Today's schedule
    • Monthly earnings
    • Date range filter
  end note

  usecase "Manage Services\n& Pricing" as P11
  note right of P11
    Add/update services
    with description &
    pricing per type
    (flat, per hour, per unit)
  end note

  usecase "Manage Payout\nMethods" as P12
  note right of P12
    CRUD bank accounts
    or e-wallets for
    receiving payments
  end note

  usecase "Update Live\nLocation" as P13
  note right of P13
    Background GPS tracking
    every 30 seconds via
    Geolocator stream
  end note

  usecase "Browse Available\nCustom Tasks" as P14
  note right of P14
    See tasks near location
    with budget & description
  end note

  usecase "Accept Custom\nTask" as P15

  usecase "Complete Custom\nTask" as P16
  note right of P16
    Triggers admin payout
    confirmation flow
  end note

  usecase "Manage\nProfile" as P17
  note right of P17
    Edit personal info,
    upload photos, portfolios,
    documents
  end note

  usecase "View\nReviews" as P18
  note right of P18
    All reviews received
    from customers
  end note

  ' ===== RELATIONSHIPS =====
  P1 ..> P3 : <<extend>>
  P6 ..> P7 : <<include>>
  P7 ..> P8 : <<include>>
  P8 ..> P9 : <<extend>>
  P14 ..> P15 : <<include>>
  P15 ..> P16 : <<include>>
}

Provider --> P1
Provider --> P2
Provider --> P4
Provider --> P5
Provider --> P6
Provider --> P10
Provider --> P11
Provider --> P12
Provider --> P13
Provider --> P14
Provider --> P17
Provider --> P18

@enduml
