@startuml Jasaku — Use Case Diagram
!theme plain
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #333333
  FontSize 12
}
skinparam actor {
  BorderColor #1A73E8
  FontSize 14
  FontStyle bold
}
skinparam rectangle {
  BorderColor #666666
  BackgroundColor #FAFAFA
  RoundCorner 10
}
skinparam note {
  BorderColor #999999
  BackgroundColor #FFFDE7
}

left to right direction

' ==================== ACTORS ====================
actor "Customer" as Customer #ADD8E6
actor "Provider\n(Mitra)" as Provider #90EE90
actor "Admin" as Admin #FFB6C1

' ==================== CUSTOMER ====================
rectangle "Customer" as C_rect #E8F4FD {
  usecase "Register" as C1
  usecase "Login\n(Email / Google)" as C2
  usecase "Browse Service\nCategories" as C3
  usecase "Find Providers\nby Distance" as C4
  usecase "View Provider\nDetail" as C5
  usecase "Create Order" as C6
  usecase "Pay via Escrow\n(Rekber)" as C7
  usecase "Track Order\n(Live Map)" as C8
  usecase "Cancel Order" as C9
  usecase "Rate & Review\nProvider" as C10
  usecase "View Order\nHistory" as C11
  usecase "Create Custom\nTask" as C12
  usecase "Manage\nProfile" as C13
  usecase "Submit\nReport" as C14
  usecase "Search\nLocation" as C15

  C6 ..> C7 : <<include>>
  C3 ..> C4 : <<include>>
  C4 ..> C5 : <<include>>
  C5 ..> C6 : <<include>>
  C9 ..> C6 : <<extend>>
  C8 ..> C6 : <<extend>>
}

' ==================== PROVIDER ====================
rectangle "Provider (Mitra)" as P_rect #E8F5E9 {
  usecase "Register\n(Multi-step)" as P1
  usecase "Login\n(Verification\nCheck)" as P2
  usecase "Resubmit\nVerification" as P3
  usecase "Complete\nOnboarding" as P4
  usecase "Toggle\nAvailability" as P5
  usecase "View Incoming\nRequests" as P6
  usecase "Accept / Reject\nOrder" as P7
  usecase "Update Order\nStatus" as P8
  usecase "Request\nExtension" as P9
  usecase "View Schedule\n& Earnings" as P10
  usecase "Manage Services\n& Pricing" as P11
  usecase " Manage Payout\nMethods" as P12
  usecase "Update Live\nLocation" as P13
  usecase "Browse Available\nCustom Tasks" as P14
  usecase "Accept Custom\nTask" as P15
  usecase "Complete Custom\nTask" as P16
  usecase "Manage\nProfile" as P17
  usecase "View\nReviews" as P18

  P1 ..> P3 : <<extend>>
  P6 ..> P7 : <<include>>
  P7 ..> P8 : <<include>>
  P8 ..> P9 : <<extend>>
  P14 ..> P15 : <<include>>
  P15 ..> P16 : <<include>>
}

' ==================== ADMIN ====================
rectangle "Admin" as A_rect #FCE4EC {
  usecase "Login" as A1
  usecase "View Dashboard\n& Metrics" as A2
  usecase "Verify Providers\n(Review KYC)" as A3
  usecase "Manage\nCategories" as A4
  usecase "Manage Services\n& Pricing Types" as A5
  usecase "Confirm Order\nPayments" as A6
  usecase "Approve / Reject\nExtensions" as A7
  usecase "Manage Users\n(Ban/Unban)" as A8
  usecase "Handle\nReports" as A9
  usecase "Manage Payment\nAccounts (Rekber)" as A10
  usecase "Confirm Custom\nTask Payments" as A11
  usecase "Send Push\nNotifications" as A12
}

