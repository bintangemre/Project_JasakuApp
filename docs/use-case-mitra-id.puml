@startuml Jasaku — Use Case Mitra (Bahasa Indonesia)
!theme plain
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #333333
  FontSize 12
}
skinparam actor {
  BorderColor #2E7D32
  FontSize 14
  FontStyle bold
}
skinparam rectangle {
  BorderColor #2E7D32
  BackgroundColor #E8F5E9
  RoundCorner 10
}
skinparam note {
  BorderColor #2E7D32
  BackgroundColor #E8F5E9
}
skinparam arrow {
  Color #2E7D32
}

left to right direction

actor "Mitra\n(Provider)" as Mitra #90EE90

rectangle "Mitra (Provider)" as MitraRect {
  usecase "Daftar Akun\n(Multi-step)" as P1
  note right of P1
    Langkah:
    1. Pilih kategori
    2. Data diri
    3. Upload dokumen
       (KTP, selfie, portofolio,
        ijazah, sertifikat)
    4. Scan KTP (OCR)
    5. Deteksi liveness
    6. Setujui syarat
    → Menunggu verifikasi admin
  end note

  usecase "Login\n(Cek Verifikasi)" as P2
  note right of P2
    Diblokir jika pending/
    ditolak. Mitra ditolak
    tetap bisa login tapi
    lihat layar penolakan
  end note

  usecase "Ajukan Ulang\nVerifikasi" as P3
  note right of P3
    Perbaiki dokumen dan
    ajukan ulang setelah
    ditolak admin
  end note

  usecase "Selesaikan\nOnboarding" as P4
  note right of P4
    Setelah terverifikasi:
    • Upload foto profil
    • Atur layanan & harga
    • Tambah metode bayar
  end note

  usecase "Atur\nKetersediaan" as P5
  note right of P5
    Toggle terpisah untuk:
    • Pesanan layanan
    • Custom task
  end note

  usecase "Lihat\nPermintaan Masuk" as P6
  note right of P6
    Pesanan pending dengan
    timer hitung mundur
    5 menit. Auto-refresh
    setiap 30 detik
  end note

  usecase "Terima / Tolak\nPesanan" as P7
  note right of P7
    Terima → status: accepted
    Tolak → status: rejected
  end note

  usecase "Update Status\nPesanan" as P8
  note right of P8
    Progres:
    accepted → on_the_way
    → arrived → in_progress
    → completed
  end note

  usecase "Minta\nPerpanjangan" as P9
  note right of P9
    Jika in_progress, minta
    tambahan 1-3 hari
    → admin setujui/tolak
  end note

  usecase "Lihat Jadwal\n& Pendapatan" as P10
  note right of P10
    • Jadwal hari ini
    • Pendapatan bulanan
    • Filter rentang tanggal
  end note

  usecase "Kelola Layanan\n& Harga" as P11
  note right of P11
    Tambah/update layanan
    dengan deskripsi &
    harga per tipe
    (flat, per jam, per unit)
  end note

  usecase "Kelola Metode\nPencairan" as P12
  note right of P12
    CRUD rekening bank
    atau e-wallet untuk
    terima pembayaran
  end note

  usecase "Update Lokasi\nLangsung" as P13
  note right of P13
    Lacak GPS latar belakang
    setiap 30 detik via
    Geolocator stream
  end note

  usecase "Cari Custom\nTask Tersedia" as P14
  note right of P14
    Lihat task di sekitar
    lokasi dengan budget
    & deskripsi
  end note

  usecase "Terima Custom\nTask" as P15

  usecase "Selesaikan\nCustom Task" as P16
  note right of P16
    Memicu alur konfirmasi
    pencairan dana oleh admin
  end note

  usecase "Kelola\nProfil" as P17
  note right of P17
    Edit data diri,
    upload foto, portofolio,
    dokumen
  end note

  usecase "Lihat\nUlasan" as P18
  note right of P18
    Semua ulasan dari
    customer
  end note

  ' ===== RELASI =====
  P1 ..> P3 : <<extend>>
  P6 ..> P7 : <<include>>
  P7 ..> P8 : <<include>>
  P8 ..> P9 : <<extend>>
  P14 ..> P15 : <<include>>
  P15 ..> P16 : <<include>>
}

Mitra --> P1
Mitra --> P2
Mitra --> P4
Mitra --> P5
Mitra --> P6
Mitra --> P10
Mitra --> P11
Mitra --> P12
Mitra --> P13
Mitra --> P14
Mitra --> P17
Mitra --> P18

@enduml
