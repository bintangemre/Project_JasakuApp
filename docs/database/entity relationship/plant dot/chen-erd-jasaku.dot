    r_ct3 -- tp_e [color="#00838F", penwidth=2]

    // --- Domain Review ---
    r_rev1 [label="1:1\nDirenview", shape=diamond, style=filled, fillcolor="#FFF9C4", color="#F9A825", fontcolor="#F57F17", fontsize=8]
    r_rev2 [label="1:N\nMelaporkan", shape=diamond, style=filled, fillcolor="#FFF9C4", color="#F9A825", fontcolor="#F57F17", fontsize=8]

    ord_e -- r_rev1 [color="#FF6F00", penwidth=2]
    r_rev1 -- rev_e [color="#FF6F00", penwidth=2]

    users_e -- r_rev2 [color="#FF6F00", penwidth=2]
    r_rev2 -- rpt_e [color="#FF6F00", penwidth=2]
}
