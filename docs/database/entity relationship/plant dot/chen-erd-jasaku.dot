    }

    // ╔═══════════════════════════════════════════════════════════╗
    // ║  DOMAIN: LAYANAN (Hijau)                                 ║
    // ╚═══════════════════════════════════════════════════════════╝

    subgraph cluster_svc_domain {
        label="DOMAIN: Layanan"
        style=filled
        fillcolor="#E8F5E922"
        color="#2E7D32"
