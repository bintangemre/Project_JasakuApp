// ============================================================
// KLASIK ERD (CHEN NOTATION) — JASAKU DATABASE
// Graphviz DOT Language — Code-to-Diagram
// shape=box (Entitas), shape=ellipse (Atribut), shape=diamond (Relasi)
// 29 Tabel · PostgreSQL + PostGIS
// ============================================================

graph chen_jasaku {
    graph [
        label="Klasik ERD (Chen Notation) — Jasaku Database\n29 Tabel · PostgreSQL + PostGIS · 6 Domain"
        labelloc=t
        fontname="Segoe UI Bold"
        fontsize=20
        bgcolor="white"
        pad="0.8"
        nodesep="0.4"
        ranksep="0.7"
        splines=true
        overlap=false
        compound=true
    ]

    node [fontname="Consolas", fontsize=8]
    edge [fontname="Segoe UI", fontsize=7]

    // Legend
    subgraph cluster_legend {
        label="LEGENDA"
        labeljust=l
        style=filled
        fillcolor="#F5F5F5"
        color="#BDBDBD"
        fontname="Segoe UI Bold"
        fontsize=10

        leg_box [label="Entitas\n(Tabel)", shape=box, style="filled,bold", fillcolor="#E0E0E0", color="#616161"]
        leg_ell [label="Atribut\n(Kolom)", shape=ellipse, style="filled,dashed", fillcolor="#F5F5F5", color="#9E9E9E"]
        leg_dia [label="Relasi\n(Relationship)", shape=diamond, style=filled, fillcolor="#FFF9C4", color="#F9A825"]

        leg_box -- leg_ell [style=invis]
        leg_ell -- leg_dia [style=invis]
    }

    // ╔═══════════════════════════════════════════════════════════╗
    // ║  DOMAIN: AUTENTIKASI & PENGGUNA (Biru)                  ║
    // ╚═══════════════════════════════════════════════════════════╝

    subgraph cluster_auth {
        label="DOMAIN: Autentikasi & Pengguna"
        style=filled
        fillcolor="#E3F2FD22"
        color="#1565C0"
        fontname="Segoe UI Bold"
        fontsize=12

        // --- roles ---
        subgraph cluster_roles {
            label="roles"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            roles_e [label="roles", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            roles_id [label="id : INT, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            roles_name [label="name : VARCHAR(50), UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            roles_desc [label="description : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            roles_created [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            roles_e -- roles_id [style=dashed, color="#90CAF9"]
            roles_e -- roles_name [style=dashed, color="#90CAF9"]
            roles_e -- roles_desc [style=dashed, color="#90CAF9"]
            roles_e -- roles_created [style=dashed, color="#90CAF9"]
        }

        // --- users ---
        subgraph cluster_users {
            label="users"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            users_e [label="users", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            users_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_rid [label="role_id : INT, FK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_email [label="email : VARCHAR(255), UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_phone [label="phone : VARCHAR(20), UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_pass [label="password_hash : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_google [label="google_id : VARCHAR(255)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_pver [label="is_phone_verified : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_ever [label="is_email_verified : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_stat [label="status : VARCHAR(20)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_cat [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            users_uat [label="updated_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            users_e -- users_id [style=dashed, color="#90CAF9"]
            users_e -- users_rid [style=dashed, color="#90CAF9"]
            users_e -- users_email [style=dashed, color="#90CAF9"]
            users_e -- users_phone [style=dashed, color="#90CAF9"]
            users_e -- users_pass [style=dashed, color="#90CAF9"]
            users_e -- users_google [style=dashed, color="#90CAF9"]
            users_e -- users_pver [style=dashed, color="#90CAF9"]
            users_e -- users_ever [style=dashed, color="#90CAF9"]
            users_e -- users_stat [style=dashed, color="#90CAF9"]
            users_e -- users_cat [style=dashed, color="#90CAF9"]
            users_e -- users_uat [style=dashed, color="#90CAF9"]
        }

        // --- profiles_customer ---
        subgraph cluster_pc {
            label="profiles_customer"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            pc_e [label="profiles_customer", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            pc_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_uid [label="user_id : UUID, FK, UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_name [label="full_name : VARCHAR(150)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_nick [label="nickname : VARCHAR(100)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_bday [label="birth_date : DATE", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_gen [label="gender : VARCHAR(10)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_addr [label="address : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_av [label="avatar_url : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_cat [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pc_uat [label="updated_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            pc_e -- pc_id [style=dashed, color="#90CAF9"]
            pc_e -- pc_uid [style=dashed, color="#90CAF9"]
            pc_e -- pc_name [style=dashed, color="#90CAF9"]
            pc_e -- pc_nick [style=dashed, color="#90CAF9"]
            pc_e -- pc_bday [style=dashed, color="#90CAF9"]
            pc_e -- pc_gen [style=dashed, color="#90CAF9"]
            pc_e -- pc_addr [style=dashed, color="#90CAF9"]
            pc_e -- pc_av [style=dashed, color="#90CAF9"]
            pc_e -- pc_cat [style=dashed, color="#90CAF9"]
            pc_e -- pc_uat [style=dashed, color="#90CAF9"]
        }

        // --- provider_profiles ---
        subgraph cluster_pp {
            label="provider_profiles"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            pp_e [label="provider_profiles", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            pp_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_uid [label="user_id : UUID, FK, UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_name [label="full_name : VARCHAR(100)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_nick [label="nickname : VARCHAR(50)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_gen [label="gender : VARCHAR(10)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_bday [label="birth_date : DATE", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_phone [label="phone : VARCHAR(20)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_addr [label="address : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_dom [label="domicile : VARCHAR(100)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_pp [label="profile_photo : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_ktp [label="ktp_photo : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_selfie [label="selfie_photo : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_ver [label="is_verified : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_vst [label="verification_status : VARCHAR(20)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_vn [label="verification_notes : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_act [label="is_active : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_onb [label="onboarding_completed : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_ta [label="task_available : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_sa [label="service_available : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_ct [label="custom_task_enabled : BOOLEAN", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_rat [label="rating : DECIMAL(2,1)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_j [label="total_jobs : INT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_tr [label="total_reviews : INT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_pf [label="portfolios : TEXT[]", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_cat [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pp_uat [label="updated_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            pp_e -- pp_id [style=dashed, color="#90CAF9"]
            pp_e -- pp_uid [style=dashed, color="#90CAF9"]
            pp_e -- pp_name [style=dashed, color="#90CAF9"]
            pp_e -- pp_nick [style=dashed, color="#90CAF9"]
            pp_e -- pp_gen [style=dashed, color="#90CAF9"]
            pp_e -- pp_bday [style=dashed, color="#90CAF9"]
            pp_e -- pp_phone [style=dashed, color="#90CAF9"]
            pp_e -- pp_addr [style=dashed, color="#90CAF9"]
            pp_e -- pp_dom [style=dashed, color="#90CAF9"]
            pp_e -- pp_pp [style=dashed, color="#90CAF9"]
            pp_e -- pp_ktp [style=dashed, color="#90CAF9"]
            pp_e -- pp_selfie [style=dashed, color="#90CAF9"]
            pp_e -- pp_ver [style=dashed, color="#90CAF9"]
            pp_e -- pp_vst [style=dashed, color="#90CAF9"]
            pp_e -- pp_vn [style=dashed, color="#90CAF9"]
            pp_e -- pp_act [style=dashed, color="#90CAF9"]
            pp_e -- pp_onb [style=dashed, color="#90CAF9"]
            pp_e -- pp_ta [style=dashed, color="#90CAF9"]
            pp_e -- pp_sa [style=dashed, color="#90CAF9"]
            pp_e -- pp_ct [style=dashed, color="#90CAF9"]
            pp_e -- pp_rat [style=dashed, color="#90CAF9"]
            pp_e -- pp_j [style=dashed, color="#90CAF9"]
            pp_e -- pp_tr [style=dashed, color="#90CAF9"]
            pp_e -- pp_pf [style=dashed, color="#90CAF9"]
            pp_e -- pp_cat [style=dashed, color="#90CAF9"]
            pp_e -- pp_uat [style=dashed, color="#90CAF9"]
        }

        // --- provider_locations ---
        subgraph cluster_pl {
            label="provider_locations"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            pl_e [label="provider_locations", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            pl_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pl_pid [label="provider_id : UUID, FK, UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pl_addr [label="address : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pl_geo [label="location : GEOMETRY", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            pl_e -- pl_id [style=dashed, color="#90CAF9"]
            pl_e -- pl_pid [style=dashed, color="#90CAF9"]
            pl_e -- pl_addr [style=dashed, color="#90CAF9"]
            pl_e -- pl_geo [style=dashed, color="#90CAF9"]
        }

        // --- provider_documents ---
        subgraph cluster_pdoc {
            label="provider_documents"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            pd_e [label="provider_documents", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            pd_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pd_pid [label="provider_id : UUID, FK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pd_type [label="type : VARCHAR(30)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pd_url [label="file_url : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pd_cat [label="category_id : UUID", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pd_desc [label="description : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            pd_created [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            pd_e -- pd_id [style=dashed, color="#90CAF9"]
            pd_e -- pd_pid [style=dashed, color="#90CAF9"]
            pd_e -- pd_type [style=dashed, color="#90CAF9"]
            pd_e -- pd_url [style=dashed, color="#90CAF9"]
            pd_e -- pd_cat [style=dashed, color="#90CAF9"]
            pd_e -- pd_desc [style=dashed, color="#90CAF9"]
            pd_e -- pd_created [style=dashed, color="#90CAF9"]
        }

        // --- provider_payout_methods ---
        subgraph cluster_ppay {
            label="provider_payout_methods"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            ppy_e [label="provider_payout_methods", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            ppy_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            ppy_pid [label="provider_id : UUID, FK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            ppy_type [label="type : VARCHAR(50)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            ppy_pn [label="provider_name : VARCHAR(100)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            ppy_an [label="account_number : VARCHAR(100)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            ppy_aname [label="account_name : VARCHAR(150)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            ppy_created [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            ppy_e -- ppy_id [style=dashed, color="#90CAF9"]
            ppy_e -- ppy_pid [style=dashed, color="#90CAF9"]
            ppy_e -- ppy_type [style=dashed, color="#90CAF9"]
            ppy_e -- ppy_pn [style=dashed, color="#90CAF9"]
            ppy_e -- ppy_an [style=dashed, color="#90CAF9"]
            ppy_e -- ppy_aname [style=dashed, color="#90CAF9"]
            ppy_e -- ppy_created [style=dashed, color="#90CAF9"]
        }

        // --- identity_verifications ---
        subgraph cluster_iv {
            label="identity_verifications"
            labeljust=c
            style=filled
            fillcolor="#E3F2FD"
            color="#1565C0"
            fontsize=9

            iv_e [label="identity_verifications", shape=box, style="filled,bold", fillcolor="#BBDEFB", color="#1565C0", fontcolor="#0D47A1", fontsize=10]
            iv_id [label="id : UUID, PK", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_pid [label="provider_id : UUID, FK, UQ", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_nik [label="nik : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_on [label="ocr_full_name : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_op [label="ocr_birth_place : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_od [label="ocr_birth_date : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_oa [label="ocr_address : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_og [label="ocr_gender : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_ob [label="ocr_blood_type : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_or [label="ocr_religion : TEXT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_oj [label="ocr_raw_result : JSONB", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_fs [label="face_match_score : FLOAT", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_fst [label="face_match_status : VARCHAR(20)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_ld [label="liveness_data : JSONB", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_lst [label="liveness_status : VARCHAR(20)", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_created [label="created_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]
            iv_verified [label="verified_at : TIMESTAMP", shape=ellipse, style="filled,dashed", fillcolor="#E3F2FD", color="#90CAF9"]

            iv_e -- iv_id [style=dashed, color="#90CAF9"]
            iv_e -- iv_pid [style=dashed, color="#90CAF9"]
            iv_e -- iv_nik [style=dashed, color="#90CAF9"]
            iv_e -- iv_on [style=dashed, color="#90CAF9"]
            iv_e -- iv_op [style=dashed, color="#90CAF9"]
            iv_e -- iv_od [style=dashed, color="#90CAF9"]
            iv_e -- iv_oa [style=dashed, color="#90CAF9"]
            iv_e -- iv_og [style=dashed, color="#90CAF9"]
            iv_e -- iv_ob [style=dashed, color="#90CAF9"]
            iv_e -- iv_or [style=dashed, color="#90CAF9"]
            iv_e -- iv_oj [style=dashed, color="#90CAF9"]
            iv_e -- iv_fs [style=dashed, color="#90CAF9"]
            iv_e -- iv_fst [style=dashed, color="#90CAF9"]
            iv_e -- iv_ld [style=dashed, color="#90CAF9"]
