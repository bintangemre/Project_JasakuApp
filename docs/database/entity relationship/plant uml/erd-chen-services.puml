@startuml ERD_Chen_Services
' ============================================================
' ERD Klasik (Chen Notation) — Domain Layanan
' Kotak = Entitas, Bulat = Atribut, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
  BackgroundColor #E8F5E9
  BorderColor #4CAF50
  FontSize 13
  FontStyle bold
  FontColor #2E7D32
}

skinparam rectangle {
  BackgroundColor #FFF3E0
  BorderColor #FF9800
  FontColor #E65100
}

' ============================================================
' ENTITAS
' ============================================================

rectangle "**categories**" as CAT {
  circle "id (UUID, PK)" as CAT_ID
  circle "name (VARCHAR 100)" as CAT_NAME
  circle "description (TEXT)" as CAT_DESC
  circle "icon_url (TEXT)" as CAT_ICON
  circle "image_url (TEXT)" as CAT_IMG
  circle "is_active (BOOLEAN)" as CAT_ACT
  circle "display_order (INT)" as CAT_ORD
}

rectangle "**services**" as SVC {
  circle "id (UUID, PK)" as S_ID
  circle "category_id (UUID, FK)" as S_CID
  circle "name (VARCHAR 100)" as S_NAME
  circle "description (TEXT)" as S_DESC
  circle "icon_url (TEXT)" as S_ICON
  circle "is_active (BOOLEAN)" as S_ACT
  circle "is_custom_task (BOOLEAN)" as S_CUSTOM
  circle "display_order (INT)" as S_ORD
}

rectangle "**pricing_types**" as PT {
  circle "id (UUID, PK)" as PT_ID
  circle "name (VARCHAR 50)" as PT_NAME
  circle "default_unit (TEXT)" as PT_UNIT
  circle "category_id (UUID, FK)" as PT_CAT
}

rectangle "**provider_services**" as PS {
  circle "id (UUID, PK)" as PS_ID
  circle "provider_id (UUID, FK)" as PS_PID
  circle "service_id (UUID, FK)" as PS_SID
  circle "is_active (BOOLEAN)" as PS_ACT
  circle "min_price (BIGINT)" as PS_MINP
  circle "description (TEXT)" as PS_DESC
}

rectangle "**provider_service_prices**" as PSP {
  circle "id (UUID, PK)" as PSP_ID
  circle "provider_service_id (UUID, FK)" as PSP_PSID
  circle "pricing_type_id (UUID, FK)" as PSP_PTID
  circle "price (BIGINT)" as PSP_PRICE
}

rectangle "**provider_schedules**" as PSC {
  circle "id (UUID, PK)" as PSC_ID
  circle "provider_id (UUID, FK)" as PSC_PID
  circle "day_of_week (INT)" as PSC_DAY
  circle "start_time (TIME)" as PSC_START
  circle "end_time (TIME)" as PSC_END
  circle "is_available (BOOLEAN)" as PSC_AVAIL
}

' ============================================================
' RELASI (Ketupat)
' ============================================================

rectangle "categories\nmemiliki\nservices" as R1 #FFECB3
rectangle "services\nmemiliki\npricing_types" as R2 #FFECB3
rectangle "provider_services\nmemiliki\nprovider_service_prices" as R3 #FFECB3
rectangle "provider\nmenyediakan\nprovider_services" as R4 #FFECB3

' ============================================================
' KONEKSI
' ============================================================

CAT_ID -down-> R1
R1 -down-> S_CID

S_ID -right-> R2
R2 -right-> PT_ID

PS_ID -down-> R3
R3 -down-> PSP_PSID

PT_ID -left-> PSP_PTID

PS_PID -down-> R4

title <b>ERD Klasik (Chen) — Domain Layanan</b>\nKotak = Entitas · Bulat = Atribut · Ketupat = Relasi\n\n6 Tabel · 4 Relasi

footer Generated by PlantUML — Jasaku Database
@enduml
