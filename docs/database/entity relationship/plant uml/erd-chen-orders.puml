@startuml ERD_Chen_Orders
' ============================================================
' ERD Klasik (Chen Notation) — Domain Pesanan
' Kotak = Entitas, Bulat = Atribut, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
  BackgroundColor #FFF3E0
  BorderColor #FF9800
  FontSize 13
  FontStyle bold
  FontColor #E65100
}

skinparam rectangle {
  BackgroundColor #FCE4EC
  BorderColor #E91E63
  FontColor #880E4F
}

' ============================================================
' ENTITAS
' ============================================================

rectangle "**orders**" as ORD {
  circle "id (UUID, PK)" as O_ID
  circle "customer_id (UUID, FK)" as O_CID
  circle "provider_id (UUID, FK)" as O_PID
  circle "service_id (UUID, FK)" as O_SID
  circle "order_number (VARCHAR 20, UQ)" as O_NUM
  circle "status (VARCHAR 20)" as O_STATUS
  circle "base_price (BIGINT)" as O_BASE
  circle "service_price (BIGINT)" as O_SP
  circle "final_price (BIGINT)" as O_FP
  circle "is_paid (BOOLEAN)" as O_PAID
  circle "estimated_duration_minutes (INT)" as O_DUR
  circle "description (TEXT)" as O_DESC
  circle "work_proof_photo_url (TEXT)" as O_PHOTO
  circle "completed_at (TIMESTAMP)" as O_CAT
  circle "deadline_at (TIMESTAMPTZ)" as O_DEAD
  circle "cancelled_at (TIMESTAMP)" as O_CANC
  circle "cancellation_reason (TEXT)" as O_CRES
  circle "completed_with_photos (BOOLEAN)" as O_CWP
  circle "work_proof_urls (JSONB)" as O_URLS
  circle "proof_delivered_at (TIMESTAMPTZ)" as O_PDAT
  circle "customer_approved_at (TIMESTAMPTZ)" as O_APROV
  circle "is_disputed (BOOLEAN)" as O_DISPU
  circle "dispute_reason (TEXT)" as O_DRES
  circle "created_at (TIMESTAMP)" as O_CAT2
  circle "updated_at (TIMESTAMP)" as O_UAT
}

rectangle "**order_items**" as OI {
  circle "id (UUID, PK)" as OI_ID
  circle "order_id (UUID, FK)" as OI_OID
  circle "pricing_type_id (UUID, FK)" as OI_PTID
  circle "quantity (INT)" as OI_QTY
  circle "base_quantity (INT)" as OI_BQTY
  circle "unit_price (BIGINT)" as OI_UP
  circle "subtotal (BIGINT)" as OI_SUB
  circle "notes (TEXT)" as OI_NOTE
  circle "pricing_label_snapshot (VARCHAR 50)" as OI_PLAB
  circle "created_at (TIMESTAMP)" as OI_CAT
}

rectangle "**order_locations**" as OL {
  circle "id (UUID, PK)" as OL_ID
  circle "order_id (UUID, FK)" as OL_OID
  circle "customer_address_id (UUID, FK, UQ)" as OL_CAID
  circle "label (VARCHAR 50)" as OL_LABEL
  circle "address (TEXT)" as OL_ADDR
  circle "location (GEOMETRY)" as OL_GEO
  circle "created_at (TIMESTAMP)" as OL_CAT
}

rectangle "**order_attachments**" as OA {
  circle "id (UUID, PK)" as OA_ID
  circle "order_id (UUID, FK)" as OA_OID
  circle "file_type (VARCHAR 50)" as OA_TYPE
  circle "file_url (TEXT)" as OA_URL
  circle "file_name (VARCHAR 255)" as OA_NAME
  circle "description (TEXT)" as OA_DESC
  circle "created_at (TIMESTAMP)" as OA_CAT
}

rectangle "**order_extensions**" as OEXT {
  circle "id (UUID, PK)" as OX_ID
  circle "order_id (UUID, FK)" as OX_OID
  circle "old_deadline_at (TIMESTAMPTZ)" as OX_OLD
  circle "new_deadline_at (TIMESTAMPTZ)" as OX_NEW
  circle "reason (TEXT)" as OX_REASON
  circle "requested_by (UUID)" as OX_REQ
  circle "status (VARCHAR 20)" as OX_STATUS
  circle "responded_at (TIMESTAMPTZ)" as OX_RESP
  circle "created_at (TIMESTAMP)" as OX_CAT
}

rectangle "**customer_addresses**" as CA {
  circle "id (UUID, PK)" as CA_ID
  circle "user_id (UUID, FK)" as CA_UID
  circle "label (VARCHAR 50)" as CA_LABEL
  circle "address (TEXT)" as CA_ADDR
  circle "location (GEOMETRY)" as CA_GEO
  circle "is_active (BOOLEAN)" as CA_ACT
  circle "is_preferred (BOOLEAN)" as CA_PREF
}

' ============================================================
' RELASI (Ketupat)
' ============================================================

rectangle "orders\nmemiliki\norder_items" as R1 #FFECB3
rectangle "orders\nmemiliki\norder_locations" as R2 #FFECB3
rectangle "orders\nmemiliki\norder_attachments" as R3 #FFECB3
rectangle "orders\nmemiliki\norder_extensions" as R4 #FFECB3
rectangle "customer\nmembuat\norders" as R5 #FFECB3
rectangle "provider\nmengerjakan\norders" as R6 #FFECB3

' ============================================================
' KONEKSI
' ============================================================

O_ID -down-> R1
R1 -down-> OI_OID

O_ID -right-> R2
R2 -right-> OL_OID

O_ID -down-> R3
R3 -down-> OA_OID

O_ID -right-> R4
R4 -right-> OX_OID

O_CID -down-> R5

O_PID -down-> R6

title <b>ERD Klasik (Chen) — Domain Pesanan</b>\nKotak = Entitas · Bulat = Atribut · Ketupat = Relasi\n\n7 Tabel · 6 Relasi

footer Generated by PlantUML — Jasaku Database
@enduml
