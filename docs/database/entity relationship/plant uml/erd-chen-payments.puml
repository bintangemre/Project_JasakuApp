@startuml ERD_Chen_Payments
' ============================================================
' ERD Klasik (Chen Notation) — Domain Pembayaran
' Kotak = Entitas, Bulat = Atribut, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
  BackgroundColor #F3E5F5
  BorderColor #9C27B0
  FontSize 13
  FontStyle bold
  FontColor #6A1B9A
}

skinparam rectangle {
  BackgroundColor #E0F7FA
  BorderColor #00BCD4
  FontColor #006064
}

' ============================================================
' ENTITAS
' ============================================================

rectangle "**payments**" as PAY {
  circle "id (UUID, PK)" as PY_ID
  circle "order_id (UUID, FK, UQ)" as PY_OID
  circle "amount (BIGINT)" as PY_AMT
  circle "method (VARCHAR 30)" as PY_METHOD
  circle "status (VARCHAR 20)" as PY_STATUS
  circle "reference_id (VARCHAR 100)" as PY_REF
  circle "payment_url (TEXT)" as PY_URL
  circle "midtrans_token (TEXT)" as PY_MTOKEN
  circle "midtrans_redirect_url (TEXT)" as PY_MREDIR
  circle "va_number (VARCHAR 50)" as PY_VA
  circle "bank (VARCHAR 50)" as PY_BANK
  circle "card_type (VARCHAR 20)" as PY_CARD
  circle "masked_card (VARCHAR 30)" as PY_MCARD
  circle "fraud_status (VARCHAR 50)" as PY_FRAUD
  circle "expiry_time (TIMESTAMP)" as PY_EXP
  circle "paid_at (TIMESTAMP)" as PY_PAID
  circle "settlement_time (TIMESTAMP)" as PY_SETT
  circle "created_at (TIMESTAMP)" as PY_CAT
  circle "updated_at (TIMESTAMP)" as PY_UAT
}

rectangle "**admin_bank_accounts**" as ABA {
  circle "id (UUID, PK)" as AB_ID
  circle "bank_name (VARCHAR 100)" as AB_BANK
  circle "account_number (VARCHAR 50)" as AB_ACCT
  circle "account_name (VARCHAR 150)" as AB_NAME
  circle "is_active (BOOLEAN)" as AB_ACT
  circle "created_at (TIMESTAMP)" as AB_CAT
}

rectangle "**admin_ewallet_accounts**" as AEW {
  circle "id (UUID, PK)" as AE_ID
  circle "ewallet_name (VARCHAR 100)" as AE_NAME
  circle "account_number (VARCHAR 50)" as AE_ACCT
  circle "account_holder (VARCHAR 150)" as AE_HOLDER
  circle "is_active (BOOLEAN)" as AE_ACT
  circle "created_at (TIMESTAMP)" as AE_CAT
}

rectangle "**admin_qris_accounts**" as AQRI {
  circle "id (UUID, PK)" as AQ_ID
  circle "provider_name (VARCHAR 100)" as AQ_PNAME
  circle "merchant_name (VARCHAR 150)" as AQ_MNAME
  circle "qris_image_url (TEXT)" as AQ_IMG
  circle "is_active (BOOLEAN)" as AQ_ACT
  circle "created_at (TIMESTAMP)" as AQ_CAT
}

' ============================================================
' RELASI (Ketupat)
' ============================================================

rectangle "orders\nmemiliki\npayments" as R1 #FFECB3

' ============================================================
' KONEKSI
' ============================================================

O_ID -[hidden]down-> PY_OID
PY_OID -down-> R1

title <b>ERD Klasik (Chen) — Domain Pembayaran</b>\nKotak = Entitas · Bulat = Atribut · Ketupat = Relasi\n\n4 Tabel · 1 Relasi\n\nadmin_bank_accounts, admin_ewallet_accounts, admin_qris_accounts\nadalah tabel referensi admin (mandiri, tidak FK ke tabel lain)

footer Generated by PlantUML — Jasaku Database
@enduml
