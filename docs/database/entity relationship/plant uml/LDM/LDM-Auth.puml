@startuml LDM_Auth
' ============================================================
' LDM — Domain Autentikasi & Pengguna
' Kotak = Entitas + Atribut + Tipe, Ketupat = Relasi + Cardinalitas
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  BorderColor #1565C0
  FontSize 11
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "**roles**" as ROLES #E3F2FD {
  rectangle "PK id : Int [Auto Increment]\nname : VarChar(50) [Unique]\ndescription : Text?\ncreated_at : Timestamp?" as R_A #BBDEFB
}

rectangle "**users**" as USERS #E3F2FD {
  rectangle "PK id : UUID\nFK role_id : Int → roles.id\nemail : VarChar(255) [Unique]?\nphone : VarChar(20) [Unique]?\npassword_hash : Text?\ngoogle_id : VarChar(255)?\nis_phone_verified : Boolean?\nis_email_verified : Boolean?\nstatus : VarChar(20)? [default: 'active']\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as U_A #BBDEFB
}

rectangle "**profiles_customer**" as PCUST #E3F2FD {
  rectangle "PK id : UUID\nFK user_id : UUID → users.id [Unique]\nfull_name : VarChar(150)\nnickname : VarChar(100)?\nbirth_date : Date?\ngender : VarChar(10)?\naddress : Text?\navatar_url : Text?\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as PC_A #BBDEFB
}

rectangle "**provider_profiles**" as PPROV #E3F2FD {
  rectangle "PK id : UUID\nFK user_id : UUID → users.id [Unique]\nfull_name : VarChar(100)\nnickname : VarChar(50)?\ngender : VarChar(10)?\nbirth_date : Date?\nphone : VarChar(20)?\naddress : Text?\ndomicile : VarChar(100)?\nprofile_photo : Text?\nktp_photo : Text?\nselfie_photo : Text?\nis_verified : Boolean?\nverification_status : VarChar(20)? [default: 'pending']\nverification_notes : Text?\nis_active : Boolean?\nonboarding_completed : Boolean?\ntask_available : Boolean?\nservice_available : Boolean\ncustom_task_enabled : Boolean?\nrating : Decimal(2,1)? [default: 0]\ntotal_jobs : Int? [default: 0]\ntotal_reviews : Int? [default: 0]\nportfolios : Text[] [default: '{}']\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as PP_A #BBDEFB
}

rectangle "**provider_locations**" as PLOC #E3F2FD {
  rectangle "PK id : UUID\nFK provider_id : UUID → users.id [Unique]\naddress : Text?\nlocation : GEOMETRY?\n\nIndex: provider_locations_geo_idx (GiST)" as PL_A #BBDEFB
}

rectangle "**provider_documents**" as PDOC #E3F2FD {
  rectangle "PK id : UUID\nFK provider_id : UUID → provider_profiles.id\ntype : VarChar(30)\nfile_url : Text\ncategory_id : UUID?\ndescription : Text?\ncreated_at : Timestamp?\n\nIndex: idx_provider_documents_provider_id" as PD_A #BBDEFB
}

rectangle "**provider_payout_methods**" as PPAY #E3F2FD {
  rectangle "PK id : UUID\nFK provider_id : UUID\ntype : VarChar(50)?\nprovider_name : VarChar(100)?\naccount_number : VarChar(100)?\naccount_name : VarChar(150)?\ncreated_at : Timestamp?" as PPY_A #BBDEFB
}

rectangle "**identity_verifications**" as IDVER #E3F2FD {
  rectangle "PK id : UUID\nFK provider_id : UUID → provider_profiles.id [Unique]\nnik : Text?\nocr_full_name : Text?\nocr_birth_place : Text?\nocr_birth_date : Text?\nocr_address : Text?\nocr_gender : Text?\nocr_blood_type : Text?\nocr_religion : Text?\nocr_raw_result : JSONB?\nface_match_score : Float?\nface_match_status : VarChar(20) [default: 'pending']\nliveness_data : JSONB?\nliveness_status : VarChar(20) [default: 'pending']\ncreated_at : Timestamp\nverified_at : Timestamp?\n\nIndex: idx_identity_verifications_provider_id" as IV_A #BBDEFB
}

rectangle "**user_devices**" as UDEV #E3F2FD {
  rectangle "PK id : UUID\nFK user_id : UUID → users.id\nfcm_token : Text [Unique]\ndevice_type : Text\ndevice_name : Text?\ncreated_at : Timestamptz\nupdated_at : Timestamptz\n\nIndex: idx_user_devices_user_id" as UD_A #BBDEFB
}

' RELASI
diamond "1:N" as D1
diamond "1:1" as D2
diamond "1:1" as D3
diamond "1:1" as D4
diamond "1:N" as D5
diamond "1:N" as D6
diamond "1:N" as D7
diamond "1:1" as D8
diamond "1:N" as D9

' KONEKSI
ROLE -down-> D1 : has
D1 -down-> USER

USER -down-> D2 : has
D2 -down-> PCUST

USER -down-> D3 : has
D3 -down-> PPROV

USER -right-> D4 : has
D4 -right-> PLOC

USER -down-> D5 : has
D5 -down-> UDEV

PPROV -down-> D6 : has
D6 -down-> PDOC

PPROV -right-> D7 : has
D7 -right-> PPAY

PPROV -down-> D8 : has
D8 -down-> IDVER

title <b>LDM — Domain Autentikasi & Pengguna</b>\n9 Tabel · Atribut + Tipe Logika + Cardinalitas

footer Generated by PlantUML — Jasaku LDM
@enduml
