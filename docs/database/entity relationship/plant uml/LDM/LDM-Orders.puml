@startuml LDM_Orders
' ============================================================
' LDM — Domain Pesanan
' Kotak = Entitas + Atribut + Tipe, Ketupat = Relasi + Cardinalitas
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  BorderColor #E65100
  FontSize 11
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "**orders**" as ORDS #FFF3E0 {
  rectangle "PK id : UUID\nFK customer_id : UUID → profiles_customer.id\nFK provider_id : UUID → provider_profiles.id\nFK custom_task_id : UUID? → custom_tasks.id\nFK task_provider_id : UUID? → task_providers.id\nstatus : VarChar(30)? [default: 'pending']\ntotal_price : Decimal(12,2)?\nplatform_fee : Decimal(12,2)?\nadditional_fee : Decimal(12,2)? [default: 0]\ndescription : Text?\nwork_date : Date?\nassignment_type : VarChar(20)? [default: 'manual']\npayout_confirmed : Boolean [default: false]\npayout_at : Timestamp?\ncreated_at : Timestamp?\nstart_date : Timestamp?\nend_date : Timestamp?" as O_A #FFE0B2
}

rectangle "**order_items**" as OITEMS #FFF3E0 {
  rectangle "PK id : UUID\nFK order_id : UUID → orders.id\nFK service_id : UUID → services.id\nFK pricing_type_id : UUID → pricing_types.id\nquantity : Int? [default: 1]\nprice : Decimal(12,2)?\nsubtotal : Decimal(12,2)?" as OI_A #FFE0B2
}

rectangle "**order_locations**" as OLOC #FFF3E0 {
  rectangle "PK id : UUID\nFK order_id : UUID → orders.id\naddress : Text?\nlocation : GEOMETRY?" as OL_A #FFE0B2
}

rectangle "**order_attachments**" as OATT #FFF3E0 {
  rectangle "PK id : UUID\nFK order_id : UUID → orders.id\nfile_url : Text\ncreated_at : Timestamp?" as OA_A #FFE0B2
}

rectangle "**order_extensions**" as OEXT #FFF3E0 {
  rectangle "PK id : UUID\nFK order_id : UUID → orders.id\nFK provider_id : UUID\nFK customer_id : UUID\nrequested_date : Date\nadditional_cost : Decimal(12,2)\nplatform_fee_rate : Decimal(3,2)\nextension_count : Int [default: 1]\nstatus : VarChar(20) [default: 'pending']\nresponse_note : Text?\ncreated_at : Timestamp?\n\nIndex: idx_order_extensions_order_id" as OX_A #FFE0B2
}

' RELASI
diamond "1:N" as D1
diamond "1:N" as D2
diamond "1:N" as D3
diamond "1:N" as D4

' KONEKSI
ORDS -down-> D1 : has
D1 -down-> OITEMS

ORDS -right-> D2 : has
D2 -right-> OLOC

ORDS -down-> D3 : has
D3 -down-> OATT

ORDS -right-> D4 : has
D4 -right-> OEXT

title <b>LDM — Domain Pesanan</b>\n5 Tabel · Atribut + Tipe Logika + Cardinalitas

footer Generated by PlantUML — Jasaku LDM
@enduml
