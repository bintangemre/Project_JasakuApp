@startuml LDM_Payments
' ============================================================
' LDM — Domain Pembayaran
' Kotak = Entitas + Atribut + Tipe, Ketupat = Relasi + Cardinalitas
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  BorderColor #6A1B9A
  FontSize 11
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "**payments**" as PAYMT #F3E5F5 {
  rectangle "PK id : UUID\nFK order_id : UUID → orders.id [Unique]\nmethod : VarChar(50)?\nstatus : VarChar(30)? [default: 'pending']\namount : Decimal(12,2)?\npaid_at : Timestamp?\ncreated_at : Timestamp?\npayment_proof : Text?" as PY_A #E1BEE7
}

rectangle "**admin_bank_accounts**" as ABA #F3E5F5 {
  rectangle "PK id : UUID\nprovider_name : VarChar(100)\naccount_number : VarChar(100)\naccount_name : VarChar(150)\nis_active : Boolean? [default: true]\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as AB_A #E1BEE7
}

rectangle "**admin_ewallet_accounts**" as AEW #F3E5F5 {
  rectangle "PK id : UUID\nprovider_name : VarChar(100)\naccount_number : VarChar(100)\naccount_name : VarChar(150)\nis_active : Boolean? [default: true]\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as AE_A #E1BEE7
}

rectangle "**admin_qris_accounts**" as AQRI #F3E5F5 {
  rectangle "PK id : UUID\nprovider_name : VarChar(100)\nqris_image_url : Text\nis_active : Boolean? [default: true]\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as AQ_A #E1BEE7
}

' RELASI
diamond "1:1" as D1

' KONEKSI
PAYMT -down-> D1 : processes

title <b>LDM — Domain Pembayaran</b>\n4 Tabel · Atribut + Tipe Logika + Cardinalitas\n\nadmin_bank/ewallet/qris = referensi mandiri

footer Generated by PlantUML — Jasaku LDM
@enduml
