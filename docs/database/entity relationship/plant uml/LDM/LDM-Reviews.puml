@startuml LDM_Reviews
' ============================================================
' LDM — Domain Review, Laporan, Notifikasi
' Kotak = Entitas + Atribut + Tipe, Ketupat = Relasi + Cardinalitas
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  BorderColor #FF6F00
  FontSize 11
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "**reviews**" as REVS #FFF8E1 {
  rectangle "PK id : UUID\nFK order_id : UUID → orders.id [Unique]\nFK customer_id : UUID → users.id\nFK provider_id : UUID → users.id\nrating : Int (CHECK 1-5)\nreview : Text?\ncreated_at : Timestamp?\nupdated_at : Timestamp?" as R_A #FFECB3
}

rectangle "**reports**" as RPTS #FFF8E1 {
  rectangle "PK id : UUID\nFK reporter_id : UUID → users.id\nreporter_role : VarChar(20)\nFK order_id : UUID?\nsubject : VarChar(200)\ndescription : Text\nattachments : Text[] [default: '{}']\nstatus : VarChar(20) [default: 'open']\nadmin_response : Text?\ncreated_at : Timestamp?\nupdated_at : Timestamp?\nresolved_at : Timestamp?\n\nIndex: idx_reports_reporter_id\nIndex: idx_reports_status" as RP_A #FFECB3
}

' RELASI
diamond "1:1" as D1
diamond "1:N" as D2

' KONEKSI
title <b>LDM — Domain Review & Laporan</b>\n2 Tabel · Atribut + Tipe Logika + Cardinalitas\n\nnotifications = FCM langsung (no table)\nlocation_history = Geolocator stream (no table)

footer Generated by PlantUML — Jasaku LDM
@enduml
