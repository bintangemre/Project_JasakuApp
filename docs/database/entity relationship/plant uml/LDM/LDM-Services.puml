@startuml LDM_Services
' ============================================================
' LDM — Domain Layanan
' Kotak = Entitas + Atribut + Tipe, Ketupat = Relasi + Cardinalitas
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  BorderColor #2E7D32
  FontSize 11
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "**categories**" as CATS #E8F5E9 {
  rectangle "PK id : UUID\nname : VarChar(100)\ndescription : Text?\nicon_url : Text?\ncreated_at : Timestamp?" as CAT_A #C8E6C9
}

rectangle "**services**" as SVCS #E8F5E9 {
  rectangle "PK id : UUID\nFK category_id : UUID → categories.id\nname : VarChar(150)\ndescription : Text?\ncreated_at : Timestamp?" as S_A #C8E6C9
}

rectangle "**pricing_types**" as PTYPES #E8F5E9 {
  rectangle "PK id : UUID\nname : VarChar(50)\ndefault_unit : Text?\nFK category_id : UUID? → categories.id" as PT_A #C8E6C9
}

rectangle "**provider_services**" as PSVCS #E8F5E9 {
  rectangle "PK id : UUID\nFK provider_id : UUID\nFK service_id : UUID → services.id\ndescription : Text?\ncreated_at : Timestamp?" as PS_A #C8E6C9
}

rectangle "**provider_service_prices**" as PSPR #E8F5E9 {
  rectangle "PK id : UUID\nFK provider_service_id : UUID → provider_services.id\nFK pricing_type_id : UUID → pricing_types.id\nprice : Decimal(12,2)\nunit : Text?\ncreated_at : Timestamp?" as PSP_A #C8E6C9
}

rectangle "**provider_schedules**" as PSCH #E8F5E9 {
  rectangle "PK id : UUID\nFK provider_id : UUID\nwork_date : Date\nis_booked : Boolean [default: false]\nFK order_id : UUID? → orders.id\ncreated_at : Timestamp?\n\nUQ: [provider_id, work_date]\nIndex: idx_provider_schedules_provider_id_work_date" as PSC_A #C8E6C9
}

' RELASI
diamond "1:N" as D1
diamond "1:N" as D2
diamond "1:N" as D3
diamond "1:N" as D4
diamond "1:N" as D5

' KONEKSI
CATS -down-> D1 : has
D1 -down-> SVCS

SVCS -right-> D2 : has
D2 -right-> PTYPES

PSVCS -down-> D3 : has
D3 -down-> PSPR

title <b>LDM — Domain Layanan</b>\n6 Tabel · Atribut + Tipe Logika + Cardinalitas

footer Generated by PlantUML — Jasaku LDM
@enduml
