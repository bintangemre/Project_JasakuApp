@startuml LDM_CustomTasks
' ============================================================
' LDM — Domain Custom Task
' Kotak = Entitas + Atribut + Tipe, Ketupat = Relasi + Cardinalitas
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  BorderColor #00838F
  FontSize 11
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "**custom_tasks**" as CTASKS #E0F7FA {
  rectangle "PK id : UUID\nFK customer_id : UUID → users.id\ntitle : VarChar(150)\ndescription : Text?\nbudget_per_person : Decimal(12,0)\nrequired_people : Int [default: 1]\naccepted_count : Int [default: 0]\nplatform_fee_rate : Decimal(4,2) [default: 5.00]\naddress : Text?\nlocation_detail : Text?\npublish_days : Int [default: 1]\nexpires_at : Timestamp?\npayment_proof : Text?\npayment_status : VarChar(30) [default: 'unpaid']\nlocation : GEOMETRY?\nstatus : VarChar(30) [default: 'open']\ncreated_at : Timestamp\nupdated_at : Timestamp" as CT_A #B2EBF2
}

rectangle "**task_locations**" as TLOC #E0F7FA {
  rectangle "PK id : UUID\nFK task_id : UUID → custom_tasks.id\nlabel : VarChar(100)?\naddress : Text\nlocation : GEOMETRY?\nstop_order : Int [default: 0]\n\nIndex: idx_task_locations_task_id" as TL_A #B2EBF2
}

rectangle "**task_providers**" as TPRV #E0F7FA {
  rectangle "PK id : UUID\nFK task_id : UUID → custom_tasks.id\nFK provider_id : UUID → provider_profiles.id\nstatus : VarChar(20) [default: 'accepted']\nwork_status : VarChar(20)?\naccepted_at : Timestamp [default: now()]\ncompleted_at : Timestamp?\npayout_confirmed : Boolean [default: false]\npayout_at : Timestamp?\n\nUQ: [task_id, provider_id]\nIndex: idx_task_providers_provider_id" as TP_A #B2EBF2
}

' RELASI
diamond "1:N" as D1
diamond "1:N" as D2

' KONEKSI
CTASKS -down-> D1 : has
D1 -down-> TLOC

CTASKS -right-> D2 : has
D2 -right-> TPRV

title <b>LDM — Domain Custom Task</b>\n3 Tabel · Atribut + Tipe Logika + Cardinalitas

footer Generated by PlantUML — Jasaku LDM
@enduml
