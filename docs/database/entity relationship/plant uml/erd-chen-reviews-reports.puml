@startuml ERD_Chen_ReviewsReports
' ============================================================
' ERD Klasik (Chen Notation) — Domain Review & Laporan
' Kotak = Entitas, Bulat = Atribut, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
  BackgroundColor #FFF8E1
  BorderColor #FFC107
  FontSize 13
  FontStyle bold
  FontColor #FF6F00
}

skinparam rectangle {
  BackgroundColor #FCE4EC
  BorderColor #E91E63
  FontColor #880E4F
}

' ============================================================
' ENTITAS
' ============================================================

rectangle "**reviews**" as REV {
  circle "id (UUID, PK)" as R_ID
  circle "order_id (UUID, FK, UQ)" as R_OID
  circle "customer_id (UUID, FK)" as R_CID
  circle "provider_id (UUID, FK)" as R_PID
  circle "rating (INT, 1-5)" as R_RATE
  circle "comment (TEXT)" as R_COMM
  circle "created_at (TIMESTAMP)" as R_CAT
}

rectangle "**reports**" as RPT {
  circle "id (UUID, PK)" as RP_ID
  circle "order_id (UUID, FK)" as RP_OID
  circle "reporter_id (UUID, FK)" as RP_RID
  circle "reported_id (UUID, FK)" as RP_RPID
  circle "reason (VARCHAR 20)" as RP_REASON
  circle "status (VARCHAR 20)" as RP_STATUS
  circle "description (TEXT)" as RP_DESC
  circle "admin_notes (TEXT)" as RP_ANOTE
  circle "resolution (TEXT)" as RP_RESOL
  circle "resolved_by (UUID)" as RP_RESBY
  circle "resolved_at (TIMESTAMP)" as RP_RESAT
  circle "created_at (TIMESTAMP)" as RP_CAT
}

rectangle "**notifications**" as NOTIF {
  circle "id (UUID, PK)" as N_ID
  circle "user_id (UUID, FK)" as N_UID
  circle "title (VARCHAR 200)" as N_TITLE
  circle "body (TEXT)" as N_BODY
  circle "type (VARCHAR 30)" as N_TYPE
  circle "data (JSONB)" as N_DATA
  circle "is_read (BOOLEAN)" as N_READ
  circle "created_at (TIMESTAMP)" as N_CAT
}

rectangle "**location_history**" as LOCH {
  circle "id (UUID, PK)" as LH_ID
  circle "user_id (UUID, FK)" as LH_UID
  circle "location (GEOMETRY)" as LH_GEO
  circle "accuracy (FLOAT)" as LH_ACC
  circle "recorded_at (TIMESTAMP)" as LH_RAT
}

' ============================================================
' RELASI (Ketupat)
' ============================================================

rectangle "orders\nmemiliki\nreviews" as R1 #FFECB3
rectangle "orders\nmemiliki\nreports" as R2 #FFECB3
rectangle "users\nmemiliki\nnotifications" as R3 #FFECB3
rectangle "providers\nmemiliki\nlocation_history" as R4 #FFECB3

' ============================================================
' KONEKSI
' ============================================================

R_ID -down-> R1

RP_ID -right-> R2

N_ID -down-> R3
R3 -down-> N_UID

LH_ID -down-> R4
R4 -down-> LH_UID

title <b>ERD Klasik (Chen) — Domain Review, Laporan, Notifikasi</b>\nKotak = Entitas · Bulat = Atribut · Ketupat = Relasi\n\n4 Tabel · 4 Relasi

footer Generated by PlantUML — Jasaku Database
@enduml
