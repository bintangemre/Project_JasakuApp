@startuml ERD_Chen_CustomTasks
' ============================================================
' ERD Klasik (Chen Notation) — Domain Custom Task
' Kotak = Entitas, Bulat = Atribut, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
  BackgroundColor #E0F7FA
  BorderColor #00BCD4
  FontSize 13
  FontStyle bold
  FontColor #006064
}

skinparam rectangle {
  BackgroundColor #F1F8E9
  BorderColor #8BC34A
  FontColor #33691E
}

' ============================================================
' ENTITAS
' ============================================================

rectangle "**custom_tasks**" as CT {
  circle "id (UUID, PK)" as CT_ID
  circle "customer_id (UUID, FK)" as CT_CID
  circle "service_id (UUID, FK)" as CT_SID
  circle "description (TEXT)" as CT_DESC
  circle "status (VARCHAR 20)" as CT_STATUS
  circle "proposed_price (BIGINT)" as CT_PP
  circle "negotiated_price (BIGINT)" as CT_NP
  circle "final_price (BIGINT)" as CT_FP
  circle "budget_min (BIGINT)" as CT_BMIN
  circle "budget_max (BIGINT)" as CT_BMAX
  circle "scheduled_date (DATE)" as CT_DATE
  circle "scheduled_time (TIME)" as CT_TIME
  circle "customer_location_id (UUID, FK)" as CT_CLID
  circle "address_snapshot (TEXT)" as CT_ADDR
  circle "deadline_at (TIMESTAMPTZ)" as CT_DEAD
  circle "completed_at (TIMESTAMP)" as CT_CAT
  circle "cancelled_at (TIMESTAMP)" as CT_CANC
  circle "cancellation_reason (TEXT)" as CT_CRES
  circle "created_at (TIMESTAMP)" as CT_CAT2
  circle "updated_at (TIMESTAMP)" as CT_UAT
}

rectangle "**task_locations**" as TLOC {
  circle "id (UUID, PK)" as TL_ID
  circle "task_id (UUID, FK)" as TL_TID
  circle "label (VARCHAR 50)" as TL_LABEL
  circle "address (TEXT)" as TL_ADDR
  circle "location (GEOMETRY)" as TL_GEO
  circle "created_at (TIMESTAMP)" as TL_CAT
}

rectangle "**task_providers**" as TPROV {
  circle "id (UUID, PK)" as TP_ID
  circle "task_id (UUID, FK)" as TP_TID
  circle "provider_id (UUID, FK)" as TP_PID
  circle "status (VARCHAR 20)" as TP_STATUS
  circle "proposed_price (BIGINT)" as TP_PP
  circle "notes (TEXT)" as TP_NOTE
  circle "responded_at (TIMESTAMPTZ)" as TP_RESP
  circle "created_at (TIMESTAMP)" as TP_CAT
}

' ============================================================
' RELASI (Ketupat)
' ============================================================

rectangle "customers\nmembuat\ncustom_tasks" as R1 #FFECB3
rectangle "custom_tasks\nmemiliki\ntask_locations" as R2 #FFECB3
rectangle "custom_tasks\nmemiliki\ntask_providers" as R3 #FFECB3
rectangle "providers\nmenerima\ntask_providers" as R4 #FFECB3

' ============================================================
' KONEKSI
' ============================================================

CT_ID -down-> R2
R2 -down-> TL_TID

CT_ID -right-> R3
R3 -right-> TP_TID

CT_CID -down-> R1

TP_PID -down-> R4

title <b>ERD Klasik (Chen) — Domain Custom Task</b>\nKotak = Entitas · Bulat = Atribut · Ketupat = Relasi\n\n3 Tabel · 4 Relasi

footer Generated by PlantUML — Jasaku Database
@enduml
