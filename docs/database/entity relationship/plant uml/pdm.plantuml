@startuml PDM_Jasaku
' ============================================================
' Physical Data Model (PDM) — Jasaku Platform
' PostgreSQL / PostGIS / Supabase
' Full column types, constraints, defaults, indexes
' ============================================================

skinparam linetype ortho
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Consolas"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam nodesep 20
skinparam ranksep 40

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #4A6FA5
  ArrowColor #4A6FA5
  FontSize 10
}

skinparam package {
  BackgroundColor<<domain>> #F0F4FF
  BorderColor<<domain>> #4A6FA5
  FontColor<<domain>> #2C3E50
  FontSize<<domain>> 12
}

' ═══════════════════════════════════════════════════════════
' DOMAIN: Authentication & Users
' ═══════════════════════════════════════════════════════════

package "Autentikasi & Pengguna" <<domain>> {

  class "roles" as ROLES <<table>> {
    id : INT <<PK>> AUTOINCREMENT
    --
    name : VARCHAR(50) <<UNIQUE>>
    description : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "users" as USERS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    role_id : INT <<FK>>
    email : VARCHAR(255) <<UNIQUE>> NULL
    phone : VARCHAR(20) <<UNIQUE>> NULL
    password_hash : TEXT NULL
    google_id : VARCHAR(255) NULL
    is_phone_verified : BOOLEAN DEFAULT false
    is_email_verified : BOOLEAN DEFAULT false
    status : VARCHAR(20) DEFAULT 'active'
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6)
    --
    <<INDEX>> idx_users_email(email)
    <<INDEX>> idx_users_google_id(google_id)
    <<INDEX>> idx_users_phone(phone)
  }

  class "profiles_customer" as PROF_CUST <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    user_id : UUID <<FK>> <<UNIQUE>>
    full_name : VARCHAR(150) NOT NULL
    nickname : VARCHAR(100) NULL
    birth_date : DATE NULL
    gender : VARCHAR(10) NULL
    address : TEXT NULL
    avatar_url : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6)
    --
    <<INDEX>> idx_profiles_user_id(user_id)
  }

  class "provider_profiles" as PROF_PROV <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    user_id : UUID <<FK>> <<UNIQUE>>
    full_name : VARCHAR(100) NOT NULL
    nickname : VARCHAR(50) NULL
    gender : VARCHAR(10) NULL
    birth_date : DATE NULL
    phone : VARCHAR(20) NULL
    address : TEXT NULL
    domicile : VARCHAR(100) NULL
    profile_photo : TEXT NULL
    ktp_photo : TEXT NULL
    selfie_photo : TEXT NULL
    is_verified : BOOLEAN DEFAULT false
    verification_status : VARCHAR(20) DEFAULT 'pending'
    verification_notes : TEXT NULL
    is_active : BOOLEAN DEFAULT true
    onboarding_completed : BOOLEAN DEFAULT false
    custom_task_enabled : BOOLEAN DEFAULT false
    service_available : BOOLEAN DEFAULT true
    task_available : BOOLEAN DEFAULT true
    rating : DECIMAL(2,1) DEFAULT 0
    total_jobs : INT DEFAULT 0
    total_reviews : INT DEFAULT 0
    portfolios : TEXT[] DEFAULT '{}'
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6)
  }

  class "provider_locations" as PROV_LOC <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_id : UUID <<FK>> <<UNIQUE>>
    address : TEXT NULL
    location : GEOMETRY(Point) NULL
    --
    <<INDEX>> provider_locations_geo_idx GIST(location)
  }

  class "provider_documents" as PROV_DOC <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_id : UUID <<FK>>
    type : VARCHAR(30) NOT NULL
    file_url : TEXT NOT NULL
    category_id : UUID NULL
    description : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
    --
    <<INDEX>> idx_provider_documents_provider_id(provider_id)
  }

  class "provider_payout_methods" as PROV_PAYOUT <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_id : UUID <<FK>> NOT NULL
    type : VARCHAR(50) NULL
    provider_name : VARCHAR(100) NULL
    account_number : VARCHAR(100) NULL
    account_name : VARCHAR(150) NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "identity_verifications" as ID_VERIF <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_id : UUID <<FK>> <<UNIQUE>>
    nik : VARCHAR NULL
    ocr_full_name : VARCHAR NULL
    ocr_birth_place : VARCHAR NULL
    ocr_birth_date : VARCHAR NULL
    ocr_address : TEXT NULL
    ocr_gender : VARCHAR NULL
    ocr_blood_type : VARCHAR NULL
    ocr_religion : VARCHAR NULL
    ocr_raw_result : JSONB NULL
    face_match_score : FLOAT NULL
    face_match_status : VARCHAR(20) DEFAULT 'pending'
    liveness_data : JSONB NULL
    liveness_status : VARCHAR(20) DEFAULT 'pending'
    created_at : TIMESTAMPTZ DEFAULT now()
    verified_at : TIMESTAMPTZ NULL
    --
    <<INDEX>> idx_identity_verifications_provider_id(provider_id)
  }

  class "user_devices" as USER_DEV <<table>> {
    id : UUID <<PK>> DEFAULT gen_random_uuid()
    --
    user_id : UUID <<FK>> NOT NULL
    fcm_token : TEXT <<UNIQUE>> NOT NULL
    device_type : VARCHAR NOT NULL
    device_name : VARCHAR NULL
    created_at : TIMESTAMPTZ DEFAULT now()
    updated_at : TIMESTAMPTZ
    --
    <<INDEX>> idx_user_devices_user_id(user_id)
  }
}

' ═══════════════════════════════════════════════════════════
' DOMAIN: Service Catalog
' ═══════════════════════════════════════════════════════════

package "Katalog Layanan" <<domain>> {

  class "categories" as CATEGORIES <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    name : VARCHAR(100) NOT NULL
    description : TEXT NULL
    icon_url : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "pricing_types" as PRICING_TYPES <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    name : VARCHAR(50) NOT NULL
    default_unit : VARCHAR NULL
    category_id : UUID <<FK>> NULL
  }

  class "services" as SERVICES <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    category_id : UUID <<FK>> NOT NULL
    name : VARCHAR(150) NOT NULL
    description : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "provider_services" as PROV_SERV <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_id : UUID <<FK>> NOT NULL
    service_id : UUID <<FK>> NOT NULL
    description : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "provider_service_prices" as PROV_PRICE <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_service_id : UUID <<FK>> NOT NULL
    pricing_type_id : UUID <<FK>> NOT NULL
    price : DECIMAL(12,2) NOT NULL
    unit : VARCHAR NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }
}

' ═══════════════════════════════════════════════════════════
' DOMAIN: Orders
' ═══════════════════════════════════════════════════════════

package "Pesanan (Orders)" <<domain>> {

  class "orders" as ORDERS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    customer_id : UUID <<FK>> NOT NULL
    provider_id : UUID <<FK>> NOT NULL
    custom_task_id : UUID <<FK>> NULL
    task_provider_id : UUID <<FK>> NULL
    status : VARCHAR(30) DEFAULT 'pending'
    total_price : DECIMAL(12,2) NULL
    platform_fee : DECIMAL(12,2) NULL
    additional_fee : DECIMAL(12,2) DEFAULT 0
    description : TEXT NULL
    work_date : DATE NULL
    start_date : TIMESTAMP(6) NULL
    end_date : TIMESTAMP(6) NULL
    assignment_type : VARCHAR(20) DEFAULT 'manual'
    payout_confirmed : BOOLEAN DEFAULT false
    payout_at : TIMESTAMP(6) NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "order_items" as ORD_ITEMS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    order_id : UUID <<FK>> NOT NULL
    service_id : UUID <<FK>> NOT NULL
    pricing_type_id : UUID <<FK>> NOT NULL
    quantity : INT DEFAULT 1
    price : DECIMAL(12,2) NULL
    subtotal : DECIMAL(12,2) NULL
  }

  class "order_locations" as ORD_LOC <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    order_id : UUID <<FK>> NOT NULL
    address : TEXT NULL
    location : GEOMETRY(Point) NULL
  }

  class "order_attachments" as ORD_ATTACH <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    order_id : UUID <<FK>> NOT NULL
    file_url : TEXT NOT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "order_extensions" as ORD_EXT <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    order_id : UUID <<FK>> NOT NULL
    provider_id : UUID <<FK>> NOT NULL
    customer_id : UUID <<FK>> NOT NULL
    requested_date : DATE NOT NULL
    additional_cost : DECIMAL(12,2) NOT NULL
    platform_fee_rate : DECIMAL(3,2) NOT NULL
    extension_count : INT DEFAULT 1
    status : VARCHAR(20) DEFAULT 'pending'
    response_note : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
    --
    <<INDEX>> idx_order_extensions_order_id(order_id)
  }

  class "provider_schedules" as PROV_SCHED <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_id : UUID <<FK>> NOT NULL
    work_date : DATE NOT NULL
    is_booked : BOOLEAN DEFAULT false
    order_id : UUID <<FK>> NULL
    created_at : TIMESTAMP(6) DEFAULT now()
    --
    <<UNIQUE>> provider_schedules_provider_id_work_date_key(provider_id, work_date)
    <<INDEX>> idx_provider_schedules_provider_id_work_date(provider_id, work_date)
  }
}

' ═══════════════════════════════════════════════════════════
' DOMAIN: Payments
' ═══════════════════════════════════════════════════════════

package "Pembayaran" <<domain>> {

  class "payments" as PAYMENTS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    order_id : UUID <<FK>> NOT NULL
    method : VARCHAR(50) NULL
    status : VARCHAR(30) DEFAULT 'pending'
    amount : DECIMAL(12,2) NULL
    paid_at : TIMESTAMP(6) NULL
    payment_proof : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
  }

  class "admin_bank_accounts" as ADMIN_BANK <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_name : VARCHAR(100) NOT NULL
    account_number : VARCHAR(100) NOT NULL
    account_name : VARCHAR(150) NOT NULL
    is_active : BOOLEAN DEFAULT true
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6) DEFAULT now()
  }

  class "admin_ewallet_accounts" as ADMIN_EWALLET <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_name : VARCHAR(100) NOT NULL
    account_number : VARCHAR(100) NOT NULL
    account_name : VARCHAR(150) NOT NULL
    is_active : BOOLEAN DEFAULT true
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6) DEFAULT now()
  }

  class "admin_qris_accounts" as ADMIN_QRIS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    provider_name : VARCHAR(100) NOT NULL
    qris_image_url : TEXT NOT NULL
    is_active : BOOLEAN DEFAULT true
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6) DEFAULT now()
  }
}

' ═══════════════════════════════════════════════════════════
' DOMAIN: Custom Tasks
' ═══════════════════════════════════════════════════════════

package "Custom Tasks (Tender)" <<domain>> {

  class "custom_tasks" as TASKS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    customer_id : UUID <<FK>> NOT NULL
    title : VARCHAR(150) NOT NULL
    description : TEXT NULL
    budget_per_person : DECIMAL(12,0) NOT NULL
    required_people : INT DEFAULT 1
    accepted_count : INT DEFAULT 0
    platform_fee_rate : DECIMAL(4,2) DEFAULT 5.00
    address : TEXT NULL
    location_detail : TEXT NULL
    publish_days : INT DEFAULT 1
    expires_at : TIMESTAMP(6) NULL
    payment_proof : TEXT NULL
    payment_status : VARCHAR(30) DEFAULT 'unpaid'
    location : GEOMETRY(Point) NULL
    status : VARCHAR(30) DEFAULT 'open'
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6)
  }

  class "task_locations" as TASK_LOC <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    task_id : UUID <<FK>> NOT NULL
    label : VARCHAR(100) NULL
    address : TEXT NOT NULL
    location : GEOMETRY(Point) NULL
    stop_order : INT DEFAULT 0
    --
    <<INDEX>> idx_task_locations_task_id(task_id)
  }

  class "task_providers" as TASK_PROV <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    task_id : UUID <<FK>> NOT NULL
    provider_id : UUID <<FK>> NOT NULL
    status : VARCHAR(20) DEFAULT 'accepted'
    work_status : VARCHAR(20) NULL
    accepted_at : TIMESTAMP(6) DEFAULT now()
    completed_at : TIMESTAMP(6) NULL
    payout_confirmed : BOOLEAN DEFAULT false
    payout_at : TIMESTAMP(6) NULL
    --
    <<UNIQUE>> task_providers_task_id_provider_id_key(task_id, provider_id)
    <<INDEX>> idx_task_providers_provider_id(provider_id)
  }
}

' ═══════════════════════════════════════════════════════════
' DOMAIN: Reviews & Reports
' ═══════════════════════════════════════════════════════════

package "Ulasan & Laporan" <<domain>> {

  class "reviews" as REVIEWS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    order_id : UUID <<FK>> <<UNIQUE>>
    customer_id : UUID <<FK>> NOT NULL
    provider_id : UUID <<FK>> NOT NULL
    rating : INT NOT NULL
    review : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6)
  }

  class "reports" as REPORTS <<table>> {
    id : UUID <<PK>> DEFAULT uuid_generate_v4()
    --
    reporter_id : UUID <<FK>> NOT NULL
    reporter_role : VARCHAR(20) NOT NULL
    order_id : UUID <<FK>> NULL
    subject : VARCHAR(200) NOT NULL
    description : TEXT NOT NULL
    attachments : TEXT[] DEFAULT '{}'
    status : VARCHAR(20) DEFAULT 'open'
    admin_response : TEXT NULL
    created_at : TIMESTAMP(6) DEFAULT now()
    updated_at : TIMESTAMP(6)
    resolved_at : TIMESTAMPTZ NULL
    --
    <<INDEX>> idx_reports_reporter_id(reporter_id)
    <<INDEX>> idx_reports_status(status)
  }
}

' ═══════════════════════════════════════════════════════════
' FOREIGN KEY RELATIONSHIPS
' ═══════════════════════════════════════════════════════════

ROLES ||--o{ USERS : "role_id FK"
USERS ||--o| PROF_CUST : "user_id FK"
USERS ||--o| PROF_PROV : "user_id FK"
USERS ||--o| PROV_LOC : "provider_id FK"
USERS ||--o{ USER_DEV : "user_id FK"
USERS ||--o{ REPORTS : "reporter_id FK"
USERS ||--o{ REVIEWS : "customer_id FK"
USERS ||--o{ REVIEWS : "provider_id FK"

PROF_PROV ||--o| ID_VERIF : "provider_id FK"
PROF_PROV ||--o{ PROV_DOC : "provider_id FK"
PROF_PROV ||--o{ PROV_PAYOUT : "provider_id FK"
PROF_PROV ||--o{ PROV_SERV : "provider_id FK"
PROF_PROV ||--o{ PROV_SCHED : "provider_id FK"
PROF_PROV ||--o{ TASK_PROV : "provider_id FK"
PROF_PROV ||--o{ ORDERS : "provider_id FK"

PROF_CUST ||--o{ ORDERS : "customer_id FK"

CATEGORIES ||--o{ PRICING_TYPES : "category_id FK"
CATEGORIES ||--o{ SERVICES : "category_id FK"
SERVICES ||--o{ PROV_SERV : "service_id FK"
SERVICES ||--o{ ORD_ITEMS : "service_id FK"
PRICING_TYPES ||--o{ PROV_PRICE : "pricing_type_id FK"

PROV_SERV ||--o{ PROV_PRICE : "provider_service_id FK"
PROV_SERV ||--o{ ORD_ITEMS : "provider_service FK"

ORDERS ||--|| PAYMENTS : "order_id FK"
ORDERS ||--o{ ORD_ITEMS : "order_id FK"
ORDERS ||--o| ORD_LOC : "order_id FK"
ORDERS ||--o{ ORD_ATTACH : "order_id FK"
ORDERS ||--o{ ORD_EXT : "order_id FK"
ORDERS ||--o| PROV_SCHED : "order_id FK"
ORDERS ||--o| REVIEWS : "order_id FK"
ORDERS }o--o| TASKS : "custom_task_id FK"
ORDERS }o--o| TASK_PROV : "task_provider_id FK"

TASKS ||--o{ TASK_LOC : "task_id FK CASCADE"
TASKS ||--o{ TASK_PROV : "task_id FK"
TASKS ||--o{ ORDERS : "custom_task FK"

TASK_PROV ||--o{ ORDERS : "task_provider FK"

' ── TITLE ──────────────────────────────────────────────────
title <b>PDM — Jasaku Platform</b>\nPhysical Data Model · PostgreSQL 15 + PostGIS\nSupabase Hosted\n\n31 Tables · All UUID PKs · 32 Foreign Keys

footer Generated by PlantUML
@enduml
