@startuml PDM_Payments
' ============================================================
' PDM — Domain Pembayaran
' Kotak = Tabel + Kolom PostgreSQL, Ketupat = FK
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Consolas"
skinparam defaultFontSize 9
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

skinparam rectangle {
  BorderColor #6A1B9A
  FontSize 10
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 8
  FontStyle bold
  FontColor #F57F17
}

' TABEL
rectangle "**payments** — Pembayaran Pesanan" as PAYMT #F3E5F5 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| order_id | UUID | **FK** → orders.id, **UNIQUE**, NOT NULL |
| method | VARCHAR(50) | NULL |
| status | VARCHAR(30) | DEFAULT 'pending' |
| amount | DECIMAL(12,2) | NULL |
| paid_at | TIMESTAMP(6) | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| payment_proof | TEXT | NULL |

**FK Name:** fk_payment_order
**RLS:** Enabled
**Status Flow:** pending → completed
" as PY_A #E1BEE7
}

rectangle "**admin_bank_accounts** — Rekening Bank Admin" as ABA #F3E5F5 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| provider_name | VARCHAR(100) | NOT NULL |
| account_number | VARCHAR(100) | NOT NULL |
| account_name | VARCHAR(150) | NOT NULL |
| is_active | BOOLEAN | DEFAULT true |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| updated_at | TIMESTAMP(6) | DEFAULT now() |

**RLS:** Enabled
**Catatan:** Tabel referensi mandiri, tidak ada FK
" as AB_A #E1BEE7
}

rectangle "**admin_ewallet_accounts** — Akun E-Wallet Admin" as AEW #F3E5F5 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| provider_name | VARCHAR(100) | NOT NULL |
| account_number | VARCHAR(100) | NOT NULL |
| account_name | VARCHAR(150) | NOT NULL |
| is_active | BOOLEAN | DEFAULT true |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| updated_at | TIMESTAMP(6) | DEFAULT now() |

**RLS:** Enabled
**Catatan:** Tabel referensi mandiri, tidak ada FK
" as AE_A #E1BEE7
}

rectangle "**admin_qris_accounts** — Akun QRIS Admin" as AQRI #F3E5F5 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| provider_name | VARCHAR(100) | NOT NULL |
| qris_image_url | TEXT | NOT NULL |
| is_active | BOOLEAN | DEFAULT true |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| updated_at | TIMESTAMP(6) | DEFAULT now() |

**RLS:** Enabled
**Catatan:** Tabel referensi mandiri, tidak ada FK
" as AQ_A #E1BEE7
}

' RELASI
diamond "FK\norders.id" as D1

PAYMT -down-> D1

title <b>PDM — Domain Pembayaran</b>\n4 Tabel · PostgreSQL Physical Schema + Constraints\n\nadmin_* = referensi mandiri (no FK)

footer Generated by PlantUML — Jasaku PDM
@enduml
