@startuml PDM_CustomTasks
' ============================================================
' PDM — Domain Custom Task
' Kotak = Tabel + Kolom PostgreSQL, Ketupat = FK
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Consolas"
skinparam defaultFontSize 9
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

skinparam rectangle {
  BorderColor #00838F
  FontSize 10
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 8
  FontStyle bold
  FontColor #F57F17
}

' TABEL
rectangle "**custom_tasks** — Tugas Kustom dari Customer" as CTASKS #E0F7FA {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| customer_id | UUID | **FK** → users.id, NOT NULL |
| title | VARCHAR(150) | NOT NULL |
| description | TEXT | NULL |
| budget_per_person | DECIMAL(12,0) | NOT NULL |
| required_people | INT | DEFAULT 1 |
| accepted_count | INT | DEFAULT 0 |
| platform_fee_rate | DECIMAL(4,2) | DEFAULT 5.00 |
| address | TEXT | NULL |
| location_detail | TEXT | NULL |
| publish_days | INT | DEFAULT 1 |
| expires_at | TIMESTAMP(6) | NULL |
| payment_proof | TEXT | NULL |
| payment_status | VARCHAR(30) | DEFAULT 'unpaid' |
| location | GEOMETRY | NULL |
| status | VARCHAR(30) | DEFAULT 'open' |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| updated_at | TIMESTAMP(6) | DEFAULT now() |

**RLS:** Enabled
**Status Flow:** open → in_progress → active → completed / fulfilled / expired / cancelled
**Payment Status:** unpaid → proof_uploaded → paid
" as CT_A #B2EBF2
}

rectangle "**task_locations** — Lokasi Tugas (PostGIS)" as TLOC #E0F7FA {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| task_id | UUID | **FK** → custom_tasks.id, NOT NULL |
| label | VARCHAR(100) | NULL |
| address | TEXT | NOT NULL |
| location | GEOMETRY | NULL |
| stop_order | INT | DEFAULT 0 |

**Indexes:** idx_task_locations_task_id
**FK On Delete:** CASCADE
**RLS:** Enabled
" as TL_A #B2EBF2
}

rectangle "**task_providers** — Provider yang Menerima Tugas" as TPRV #E0F7FA {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| task_id | UUID | **FK** → custom_tasks.id, NOT NULL |
| provider_id | UUID | **FK** → provider_profiles.id, NOT NULL |
| status | VARCHAR(20) | DEFAULT 'accepted' |
| work_status | VARCHAR(20) | NULL |
| accepted_at | TIMESTAMP(6) | DEFAULT now() |
| completed_at | TIMESTAMP(6) | NULL |
| payout_confirmed | BOOLEAN | DEFAULT false |
| payout_at | TIMESTAMP(6) | NULL |

**Unique:** [task_id, provider_id]
**Indexes:** idx_task_providers_provider_id
**RLS:** Enabled
**Status Flow:** accepted → completed
**Work Status:** null → on_the_way → arrived → in_progress → completed
" as TP_A #B2EBF2
}

' RELASI
diamond "FK\ncustom_tasks.id\n(CASCADE)" as D1
diamond "FK\ncustom_tasks.id" as D2
diamond "FK\nprovider_profiles.id" as D3

CTASKS -down-> D1
D1 -down-> TLOC

CTASKS -right-> D2
D2 -right-> TPRV

title <b>PDM — Domain Custom Task</b>\n3 Tabel · PostgreSQL Physical Schema + Constraints

footer Generated by PlantUML — Jasaku PDM
@enduml
