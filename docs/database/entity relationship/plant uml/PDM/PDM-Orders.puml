@startuml PDM_Orders
' ============================================================
' PDM — Domain Pesanan
' Kotak = Tabel + Kolom PostgreSQL, Ketupat = FK
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Consolas"
skinparam defaultFontSize 9
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

skinparam rectangle {
  BorderColor #E65100
  FontSize 10
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 8
  FontStyle bold
  FontColor #F57F17
}

' TABEL
rectangle "**orders** — Pesanan Utama" as ORDS #FFF3E0 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| customer_id | UUID | **FK** → profiles_customer.id, NOT NULL |
| provider_id | UUID | **FK** → provider_profiles.id, NOT NULL |
| custom_task_id | UUID | **FK** → custom_tasks.id, NULL |
| task_provider_id | UUID | **FK** → task_providers.id, NULL |
| status | VARCHAR(30) | DEFAULT 'pending' |
| total_price | DECIMAL(12,2) | NULL |
| platform_fee | DECIMAL(12,2) | NULL |
| additional_fee | DECIMAL(12,2) | DEFAULT 0 |
| description | TEXT | NULL |
| work_date | DATE | NULL |
| assignment_type | VARCHAR(20) | DEFAULT 'manual' |
| payout_confirmed | BOOLEAN | DEFAULT false |
| payout_at | TIMESTAMP(6) | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| start_date | TIMESTAMP(6) | NULL |
| end_date | TIMESTAMP(6) | NULL |

**RLS:** Enabled
**Status Flow:** pending → accepted → on_the_way → arrived → in_progress → completed
" as O_A #FFE0B2
}

rectangle "**order_items** — Item Pesanan" as OITEMS #FFF3E0 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| order_id | UUID | **FK** → orders.id, NOT NULL |
| service_id | UUID | **FK** → services.id, NOT NULL |
| pricing_type_id | UUID | **FK** → pricing_types.id, NOT NULL |
| quantity | INT | DEFAULT 1 |
| price | DECIMAL(12,2) | NULL |
| subtotal | DECIMAL(12,2) | NULL |

**FK Names:** fk_order, fk_service
**RLS:** Enabled
" as OI_A #FFE0B2
}

rectangle "**order_locations** — Lokasi Pesanan (PostGIS)" as OLOC #FFF3E0 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| order_id | UUID | **FK** → orders.id, NOT NULL |
| address | TEXT | NULL |
| location | GEOMETRY | NULL |

**FK Name:** fk_order_location
**RLS:** Enabled
" as OL_A #FFE0B2
}

rectangle "**order_attachments** — Lampiran Bukti" as OATT #FFF3E0 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| order_id | UUID | **FK** → orders.id, NOT NULL |
| file_url | TEXT | NOT NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**FK Name:** fk_order_attachment
**RLS:** Enabled
" as OA_A #FFE0B2
}

rectangle "**order_extensions** — Perpanjangan Deadline" as OEXT #FFF3E0 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| order_id | UUID | **FK** → orders.id, NOT NULL |
| provider_id | UUID | NOT NULL |
| customer_id | UUID | NOT NULL |
| requested_date | DATE | NOT NULL |
| additional_cost | DECIMAL(12,2) | NOT NULL |
| platform_fee_rate | DECIMAL(3,2) | NOT NULL |
| extension_count | INT | DEFAULT 1 |
| status | VARCHAR(20) | DEFAULT 'pending' |
| response_note | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**Indexes:** idx_order_extensions_order_id
**RLS:** Enabled
**Status Flow:** pending → accepted / rejected
" as OX_A #FFE0B2
}

' RELASI
diamond "FK\norders.id\n(CASCADE)" as D1
diamond "FK\norders.id" as D2
diamond "FK\norders.id" as D3
diamond "FK\norders.id" as D4

ORDS -down-> D1
D1 -down-> OITEMS

ORDS -right-> D2
D2 -right-> OLOC

ORDS -down-> D3
D3 -down-> OATT

ORDS -right-> D4
D4 -right-> OEXT

title <b>PDM — Domain Pesanan</b>\n5 Tabel · PostgreSQL Physical Schema + Constraints

footer Generated by PlantUML — Jasaku PDM
@enduml
