@startuml PDM_Services
' ============================================================
' PDM — Domain Layanan
' Kotak = Tabel + Kolom PostgreSQL, Ketupat = FK
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Consolas"
skinparam defaultFontSize 9
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

skinparam rectangle {
  BorderColor #2E7D32
  FontSize 10
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 8
  FontStyle bold
  FontColor #F57F17
}

' TABEL
rectangle "**categories** — Kategori Layanan" as CATS #E8F5E9 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| name | VARCHAR(100) | NOT NULL |
| description | TEXT | NULL |
| icon_url | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**RLS:** Enabled
" as CAT_A #C8E6C9
}

rectangle "**services** — Layanan/Tugas" as SVCS #E8F5E9 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| category_id | UUID | **FK** → categories.id, NOT NULL |
| name | VARCHAR(150) | NOT NULL |
| description | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**FK Name:** fk_service_category
**RLS:** Enabled
" as S_A #C8E6C9
}

rectangle "**pricing_types** — Tipe Harga Satuan" as PTYPES #E8F5E9 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| name | VARCHAR(50) | NOT NULL |
| default_unit | TEXT | NULL |
| category_id | UUID | **FK** → categories.id, NULL |

**RLS:** Enabled
" as PT_A #C8E6C9
}

rectangle "**provider_services** — Layanan yang Ditawarkan Provider" as PSVCS #E8F5E9 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| provider_id | UUID | **FK** → users.id, NOT NULL |
| service_id | UUID | **FK** → services.id, NOT NULL |
| description | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**RLS:** Enabled
" as PS_A #C8E6C9
}

rectangle "**provider_service_prices** — Harga per Tipe Satuan" as PSPR #E8F5E9 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| provider_service_id | UUID | **FK** → provider_services.id, NOT NULL |
| pricing_type_id | UUID | **FK** → pricing_types.id, NOT NULL |
| price | DECIMAL(12,2) | NOT NULL |
| unit | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**FK Names:** fk_ps_price, fk_price_type
**RLS:** Enabled
" as PSP_A #C8E6C9
}

rectangle "**provider_schedules** — Jadwal Kerja Provider" as PSCH #E8F5E9 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| provider_id | UUID | **FK** → users.id, NOT NULL |
| work_date | DATE | NOT NULL |
| is_booked | BOOLEAN | DEFAULT false |
| order_id | UUID | **FK** → orders.id, NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |

**Unique:** [provider_id, work_date]
**Indexes:** idx_provider_schedules_provider_id_work_date
**RLS:** Enabled
" as PSC_A #C8E6C9
}

' RELASI
diamond "FK\ncategories.id" as D1
diamond "FK\nservices.id" as D2
diamond "FK\nprovider_services.id" as D3
diamond "FK\npricing_types.id" as D4

CATS -right-> D1
D1 -right-> SVCS

PSVCS -down-> D2
D2 -down-> PSPR

PSPR -down-> D3

title <b>PDM — Domain Layanan</b>\n6 Tabel · PostgreSQL Physical Schema + Constraints

footer Generated by PlantUML — Jasaku PDM
@enduml
