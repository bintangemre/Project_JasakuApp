@startuml PDM_Reviews
' ============================================================
' PDM — Domain Review, Laporan, Notifikasi
' Kotak = Tabel + Kolom PostgreSQL, Ketupat = FK
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Consolas"
skinparam defaultFontSize 9
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

skinparam rectangle {
  BorderColor #FF6F00
  FontSize 10
  FontStyle bold
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 8
  FontStyle bold
  FontColor #F57F17
}

' TABEL
rectangle "**reviews** — Ulasan Customer" as REVS #FFF8E1 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| order_id | UUID | **FK** → orders.id, **UNIQUE**, ON DELETE CASCADE |
| customer_id | UUID | **FK** → users.id, ON DELETE CASCADE |
| provider_id | UUID | **FK** → users.id, ON DELETE CASCADE |
| rating | INT | NOT NULL, **CHECK** (rating >= 1 AND rating <= 5) |
| review | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| updated_at | TIMESTAMP(6) | DEFAULT now() |

**FK Names:** fk_review_customer, fk_review_order, fk_review_provider
**CHECK Constraint:** rating >= 1 AND rating <= 5
**RLS:** Enabled
" as R_A #FFECB3
}

rectangle "**reports** — Laporan/Pengaduan" as RPTS #FFF8E1 {
  rectangle "
| Kolum | Tipe | Constraint |
|-------|------|------------|
| id | UUID | **PK** DEFAULT uuid_generate_v4() |
| reporter_id | UUID | **FK** → users.id, NOT NULL |
| reporter_role | VARCHAR(20) | NOT NULL |
| order_id | UUID | NULL |
| subject | VARCHAR(200) | NOT NULL |
| description | TEXT | NOT NULL |
| attachments | TEXT[] | DEFAULT '{}' |
| status | VARCHAR(20) | DEFAULT 'open' |
| admin_response | TEXT | NULL |
| created_at | TIMESTAMP(6) | DEFAULT now() |
| updated_at | TIMESTAMP(6) | DEFAULT now() |
| resolved_at | TIMESTAMP(6) | NULL |

**Indexes:** idx_reports_reporter_id, idx_reports_status
**RLS:** Enabled
**Status Flow:** open → in_review → resolved / dismissed
" as RP_A #FFECB3
}

' NOTE
rectangle "**notifications** — TIDAK ADA TABEL" as NOTIF #FFF8E1 {
  rectangle "
Push notifications dikirim langsung via Firebase Admin SDK.\nTidak ada tabel persistent — token FCM disimpan di user_devices.\nNotifikasi in-app belum diimplementasi.
" as N_A #FFECB3
}

rectangle "**location_history** — TIDAK ADA TABEL" as LOCHIST #FFF8E1 {
  rectangle "
Lokasi provider dikirim real-time via Geolocator stream.\nEndpoint: PUT /api/locations/update\nTidak ada tabel riwayat persistent.\nLokasi live disimpan di memori / provider_locations.
" as LH_A #FFECB3
}

' RELASI
diamond "FK\nusers.id\n(CASCADE)" as D1
diamond "FK\nusers.id" as D2

RPTS -down-> D1
RPTS -down-> D2

title <b>PDM — Domain Review, Laporan, Notifikasi</b>\n2 Tabel Aktif · PostgreSQL Physical Schema + Constraints\n\nnotifications & location_history = tidak ada tabel

footer Generated by PlantUML — Jasaku PDM
@enduml
