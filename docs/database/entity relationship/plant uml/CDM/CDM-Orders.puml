@startuml CDM_Orders
' ============================================================
' CDM — Domain Pesanan
' Kotak = Entitas, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #FFF3E0
  BorderColor #E65100
  FontSize 12
  FontStyle bold
  FontColor #BF360C
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "Order" as ORD
rectangle "Order\nItem" as OI
rectangle "Order\nLocation" as OL
rectangle "Order\nAttachment" as OA
rectangle "Order\nExtension" as OEXT
rectangle "Customer\nAddress" as CA

' RELASI
diamond "1:N" as D1
diamond "1:N" as D2
diamond "1:N" as D3
diamond "1:N" as D4
diamond "1:N" as D5

' KONEKSI
ORD -down-> D1
D1 -down-> OI

ORD -right-> D2
D2 -right-> OL

ORD -down-> D3
D3 -down-> OA

ORD -right-> D4
D4 -right-> OEXT

ORD -down-> D5
D5 -down-> CA

title <b>CDM — Domain Pesanan</b>\n6 Entitas · Relasi Bisnis

footer Generated by PlantUML — Jasaku CDM
@enduml
