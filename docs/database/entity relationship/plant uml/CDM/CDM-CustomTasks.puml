@startuml CDM_CustomTasks
' ============================================================
' CDM — Domain Custom Task
' Kotak = Entitas, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #E0F7FA
  BorderColor #00838F
  FontSize 12
  FontStyle bold
  FontColor #006064
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "Custom\nTask" as CT
rectangle "Task\nLocation" as TL
rectangle "Task\nProvider" as TP

' RELASI
diamond "1:N" as D1
diamond "1:N" as D2

' KONEKSI
CT -down-> D1
D1 -down-> TL

CT -right-> D2
D2 -right-> TP

title <b>CDM — Domain Custom Task</b>\n3 Entitas · Relasi Bisnis

footer Generated by PlantUML — Jasaku CDM
@enduml
