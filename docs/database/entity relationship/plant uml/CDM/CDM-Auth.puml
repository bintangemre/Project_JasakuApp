@startuml CDM_Auth
' ============================================================
' CDM — Domain Autentikasi & Pengguna
' Kotak = Entitas, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontSize 12
  FontStyle bold
  FontColor #0D47A1
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "Role" as ROLE
rectangle "User" as USER
rectangle "Profile\nCustomer" as PCUST
rectangle "Provider\nProfile" as PPROV
rectangle "Provider\nLocation" as PLOC
rectangle "Provider\nDocument" as PDOC
rectangle "Provider\nPayout\nMethod" as PPAY
rectangle "Identity\nVerification" as IDVER
rectangle "User\nDevice" as UDEV

' RELASI
diamond "1:N" as D1
diamond "1:1" as D2
diamond "1:1" as D3
diamond "1:1" as D4
diamond "1:N" as D5
diamond "1:N" as D6
diamond "1:N" as D7
diamond "1:1" as D8
diamond "1:N" as D9

' KONEKSI
ROLE -down-> D1
D1 -down-> USER

USER -down-> D2
D2 -down-> PCUST

USER -down-> D3
D3 -down-> PPROV

USER -right-> D4
D4 -right-> PLOC

USER -down-> D5
D5 -down-> UDEV

PPROV -down-> D6
D6 -down-> PDOC

PPROV -right-> D7
D7 -right-> PPAY

PPROV -down-> D8
D8 -down-> IDVER

title <b>CDM — Domain Autentikasi & Pengguna</b>\n9 Entitas · Relasi Bisnis

footer Generated by PlantUML — Jasaku CDM
@enduml
