@startuml CDM_Payments
' ============================================================
' CDM — Domain Pembayaran
' Kotak = Entitas, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #F3E5F5
  BorderColor #6A1B9A
  FontSize 12
  FontStyle bold
  FontColor #4A148C
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "Payment" as PAY
rectangle "Admin\nBank\nAccount" as ABA
rectangle "Admin\nE-Wallet\nAccount" as AEW
rectangle "Admin\nQRIS\nAccount" as AQRI

' RELASI
diamond "1:1" as D1

' KONEKSI
PAY -down-> D1

title <b>CDM — Domain Pembayaran</b>\n4 Entitas · Relasi Bisnis\n\nAdmin accounts adalah referensi mandiri (tidak FK)

footer Generated by PlantUML — Jasaku CDM
@enduml
