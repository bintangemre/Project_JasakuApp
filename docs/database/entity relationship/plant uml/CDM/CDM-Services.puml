@startuml CDM_Services
' ============================================================
' CDM — Domain Layanan
' Kotak = Entitas, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
  FontSize 12
  FontStyle bold
  FontColor #1B5E20
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "Category" as CAT
rectangle "Service" as SVC
rectangle "Pricing\nType" as PT
rectangle "Provider\nService" as PSVC
rectangle "Provider\nService\nPrice" as PSP
rectangle "Provider\nSchedule" as PSCH

' RELASI
diamond "1:N" as D1
diamond "1:N" as D2
diamond "1:N" as D3
diamond "1:N" as D4
diamond "1:N" as D5

' KONEKSI
CAT -down-> D1
D1 -down-> SVC

SVC -right-> D2
D2 -right-> PT

SVC -down-> D3
D3 -down-> PSVC

PSVC -down-> D4
D4 -down-> PSP

PSVC -right-> D5
D5 -right-> PSCH

title <b>CDM — Domain Layanan</b>\n6 Entitas · Relasi Bisnis

footer Generated by PlantUML — Jasaku CDM
@enduml
