@startuml CDM_Reviews
' ============================================================
' CDM — Domain Review, Laporan, Notifikasi
' Kotak = Entitas, Ketupat = Relasi
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

skinparam rectangle {
  BackgroundColor #FFF8E1
  BorderColor #FF6F00
  FontSize 12
  FontStyle bold
  FontColor #E65100
}

skinparam diamond {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontSize 9
  FontStyle bold
  FontColor #F57F17
}

' ENTITAS
rectangle "Review" as REV
rectangle "Report" as RPT
rectangle "Notification" as NOTIF
rectangle "Location\nHistory" as LH

' RELASI
diamond "1:1" as D1
diamond "1:N" as D2
diamond "1:N" as D3
diamond "1:N" as D4

' KONEKSI
REV -down-> D1

RPT -right-> D2

NOTIF -down-> D3

LH -down-> D4

title <b>CDM — Domain Review, Laporan, Notifikasi</b>\n4 Entitas · Relasi Bisnis

footer Generated by PlantUML — Jasaku CDM
@enduml
