generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String     @db.VarChar(100)
  description String?
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  services    services[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model custom_task_proposals {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  task_id      String?       @db.Uuid
  provider_id  String?       @db.Uuid
  price        Decimal?      @db.Decimal
  message      String?
  status       String?       @default("pending") @db.VarChar(20)
  users        users?        @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  custom_tasks custom_tasks? @relation(fields: [task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model custom_tasks {
  id                    String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id           String?                  @db.Uuid
  title                 String?                  @db.VarChar(150)
  description           String?
  budget_min            Decimal?                 @db.Decimal
  budget_max            Decimal?                 @db.Decimal
  location              Unsupported("geometry")?
  status                String?                  @default("open") @db.VarChar(30)
  created_at            DateTime?                @default(now()) @db.Timestamp(6)
  custom_task_proposals custom_task_proposals[]
  users                 users?                   @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model customer_payment_methods {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String    @db.Uuid
  type           String?   @db.VarChar(50)
  account_number String?   @db.VarChar(100)
  account_name   String?   @db.VarChar(150)
  provider_name  String?   @db.VarChar(100)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_attachments {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id   String    @db.Uuid
  file_url   String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  orders     orders    @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_attachment")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_items {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id        String   @db.Uuid
  service_id      String   @db.Uuid
  pricing_type_id String   @db.Uuid
  quantity        Int?     @default(1)
  price           Decimal? @db.Decimal(12, 2)
  subtotal        Decimal? @db.Decimal(12, 2)
  orders          orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order")
  services        services @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_service")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_locations {
  id       String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id String                   @db.Uuid
  address  String?
  location Unsupported("geometry")?
  orders   orders                   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_location")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id       String              @db.Uuid
  provider_id       String              @db.Uuid
  status            String?             @default("pending") @db.VarChar(30)
  total_price       Decimal?            @db.Decimal(12, 2)
  description       String?
  work_date         DateTime?           @db.Date
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  order_attachments order_attachments[]
  order_items       order_items[]
  order_locations   order_locations[]
  payments          payments[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id   String    @db.Uuid
  method     String?   @db.VarChar(50)
  status     String?   @default("pending") @db.VarChar(30)
  amount     Decimal?  @db.Decimal(12, 2)
  paid_at    DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  orders     orders    @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_order")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pricing_types {
  id                      String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                    String                    @db.VarChar(50)
  description             String?
  default_unit            String?
  provider_service_prices provider_service_prices[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model provider_payout_methods {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  provider_id    String    @db.Uuid
  type           String?   @db.VarChar(50)
  provider_name  String?   @db.VarChar(100)
  account_number String?   @db.VarChar(100)
  account_name   String?   @db.VarChar(150)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model provider_service_prices {
  id                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  provider_service_id String            @db.Uuid
  pricing_type_id     String            @db.Uuid
  price               Decimal           @db.Decimal(12, 2)
  created_at          DateTime?         @default(now()) @db.Timestamp(6)
  unit                String?
  pricing_types       pricing_types     @relation(fields: [pricing_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_price_type")
  provider_services   provider_services @relation(fields: [provider_service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ps_price")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model provider_services {
  id                      String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  provider_id             String                    @db.Uuid
  service_id              String                    @db.Uuid
  description             String?
  created_at              DateTime?                 @default(now()) @db.Timestamp(6)
  provider_service_prices provider_service_prices[]
  services                services                  @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model services {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  category_id       String              @db.Uuid
  name              String              @db.VarChar(150)
  description       String?
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  order_items       order_items[]
  provider_services provider_services[]
  categories        categories          @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_service_category")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  role_id               Int
  email                 String?                 @unique @db.VarChar(255)
  phone                 String?                 @unique @db.VarChar(20)
  password_hash         String?
  google_id             String?                 @db.VarChar(255)
  is_phone_verified     Boolean?                @default(false)
  is_email_verified     Boolean?                @default(false)
  status                String?                 @default("active") @db.VarChar(20)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  custom_task_proposals custom_task_proposals[]
  custom_tasks          custom_tasks[]
  profiles_customer     profiles_customer?
  provider_profiles     provider_profiles?
  roles                 roles                   @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_role")

  @@index([email], map: "idx_users_email")
  @@index([google_id], map: "idx_users_google_id")
  @@index([phone], map: "idx_users_phone")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles_customer {
  id         String    @id(map: "profiles_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @unique(map: "profiles_user_id_key") @db.Uuid
  full_name  String    @db.VarChar(150)
  nickname   String?   @db.VarChar(100)
  birth_date DateTime? @db.Date
  gender     String?   @db.VarChar(10)
  avatar_url String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_profile_user")

  @@index([user_id], map: "idx_profiles_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model provider_profiles {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String    @unique @db.Uuid
  full_name           String    @db.VarChar(100)
  nickname            String?   @db.VarChar(50)
  gender              String?   @db.VarChar(10)
  birth_date          DateTime? @db.Date
  phone               String?   @db.VarChar(20)
  address             String?
  domicile            String?   @db.VarChar(100)
  profile_photo       String?
  ktp_photo           String?
  selfie_photo        String?
  is_verified         Boolean?  @default(false)
  verification_status String?   @default("pending") @db.VarChar(20)
  is_active           Boolean?  @default(true)
  rating              Decimal?  @default(0) @db.Decimal(2, 1)
  total_jobs          Int?      @default(0)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  users               users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_provider_user")
}
